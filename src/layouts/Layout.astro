---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  faqs?: Array<{ question: string; answer: string }>;
}

const { title, description, faqs } = Astro.props;

// Auto-generate canonical URL
const canonicalUrl = new URL(Astro.url.pathname, 'https://isitkitchensafe.com').href.replace(/\/$/, '');

// Generate FAQ JSON-LD Schema
const faqSchema = faqs && faqs.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
} : null;

// Generate WebSite Schema for homepage
const isHome = Astro.url.pathname === '/' || Astro.url.pathname === '';
const siteSchema = isHome ? {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Is It Kitchen Safe?",
  "url": "https://isitkitchensafe.com",
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "https://isitkitchensafe.com/?q={search_term_string}"
    },
    "query-input": "required name=search_term_string"
  }
} : null;

const appliances = [
  { name: 'Dishwasher', slug: 'dishwasher' },
  { name: 'Microwave', slug: 'microwave' },
  { name: 'Freezer', slug: 'freezer' },
  { name: 'Oven', slug: 'oven' },
  { name: 'Dryer', slug: 'dryer' },
  { name: 'Air Fryer', slug: 'airfryer' },
  { name: 'Refrigerator', slug: 'refrigerator' }
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='20' fill='%23181d26'/><text y='75' font-size='70' x='15' fill='white'>✓</text></svg>">
    <meta name="generator" content={Astro.generator} />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalUrl} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet" />

    <!-- Schema Markup -->
    {faqSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    )}
    {siteSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(siteSchema)} />
    )}

    <!-- Google Analytics Placeholder -->
    <script is:inline src="https://www.googletagmanager.com/gtag/js?id=G-PLACEHOLDER" async></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-PLACEHOLDER', { 'anonymize_ip': true });
    </script>
  </head>
  <body class="bg-canvas text-body font-sans selection:bg-signature-cream selection:text-ink min-h-screen flex flex-col">
    <!-- Header -->
    <header class="h-[64px] border-b border-hairline bg-canvas sticky top-0 z-50">
      <div class="max-w-[1280px] mx-auto px-6 h-full flex items-center justify-between">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2 group" id="site-logo">
          <span class="w-8 h-8 rounded-lg bg-primary flex items-center justify-center text-on-primary font-display font-medium text-lg transition-transform group-active:scale-95">✓</span>
          <span class="text-ink font-display font-medium text-[16px] md:text-[18px] tracking-tight">Is It Kitchen Safe?</span>
        </a>

        <!-- Desktop Navigation -->
        <nav class="hidden lg:flex items-center gap-6" id="desktop-nav">
          {appliances.map(app => (
            <a 
              href={`/${app.slug}`} 
              class="text-body hover:text-ink text-[14px] font-normal transition-colors"
            >
              {app.name}
            </a>
          ))}
          <a href="/about" class="text-muted hover:text-ink text-[14px] font-normal transition-colors border-l border-hairline pl-4">About</a>
        </nav>

        <!-- Mobile Menu Toggle Button (Client-side interactivity using raw JS) -->
        <button 
          type="button"
          id="mobile-menu-toggle"
          class="lg:hidden p-2 text-ink hover:bg-surface-soft rounded-md active:scale-95 transition-transform"
          aria-label="Toggle Menu"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </header>

    <!-- Mobile Navigation Panel (Full screen overlay as per DESIGN.md: collapses to full sheet) -->
    <div 
      id="mobile-menu"
      class="fixed inset-0 bg-canvas z-40 transform translate-x-full transition-transform duration-300 lg:hidden flex flex-col pt-20 px-6"
    >
      <button 
        type="button"
        id="mobile-menu-close"
        class="absolute top-4 right-6 p-2 text-ink hover:bg-surface-soft rounded-md"
        aria-label="Close Menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
      <nav class="flex flex-col gap-6 text-center text-lg mt-8">
        {appliances.map(app => (
          <a 
            href={`/${app.slug}`} 
            class="text-ink font-display font-medium text-xl py-2 border-b border-surface-soft active:bg-surface-soft rounded-md transition-colors"
          >
            {app.name}
          </a>
        ))}
        <div class="border-t border-hairline my-4"></div>
        <a href="/about" class="text-body font-normal py-2 active:bg-surface-soft rounded-md transition-colors">About Us</a>
        <a href="/contact" class="text-body font-normal py-2 active:bg-surface-soft rounded-md transition-colors">Contact</a>
        <a href="/privacy" class="text-body font-normal py-2 active:bg-surface-soft rounded-md transition-colors">Privacy Policy</a>
      </nav>
    </div>

    <!-- Main Content -->
    <main class="flex-grow">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-canvas border-t border-hairline py-[64px]" id="site-footer">
      <div class="max-w-[1280px] mx-auto px-6 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
        <div class="flex flex-col gap-4">
          <div class="flex items-center gap-2">
            <span class="w-6 h-6 rounded-md bg-primary flex items-center justify-center text-on-primary font-display font-medium text-sm">✓</span>
            <span class="text-ink font-display font-medium text-[16px] tracking-tight">Is It Kitchen Safe?</span>
          </div>
          <p class="text-muted text-[13px] leading-relaxed max-w-sm">
            Quick, reliable safety guides for kitchen appliances. Find out whether you can put food containers, cookware, or utensils in the microwave, dishwasher, freezer, and more.
          </p>
        </div>

        <div>
          <h3 class="text-ink font-semibold text-[14px] uppercase tracking-wider mb-4">Appliances</h3>
          <ul class="flex flex-col gap-2.5">
            {appliances.slice(0, 4).map(app => (
              <li>
                <a href={`/${app.slug}`} class="text-muted hover:text-ink text-[14px] transition-colors">{app.name} Guides</a>
              </li>
            ))}
          </ul>
        </div>

        <div>
          <h3 class="text-ink font-semibold text-[14px] uppercase tracking-wider mb-4">More Appliances</h3>
          <ul class="flex flex-col gap-2.5">
            {appliances.slice(4).map(app => (
              <li>
                <a href={`/${app.slug}`} class="text-muted hover:text-ink text-[14px] transition-colors">{app.name} Guides</a>
              </li>
            ))}
          </ul>
        </div>

        <div>
          <h3 class="text-ink font-semibold text-[14px] uppercase tracking-wider mb-4">Legal & Contact</h3>
          <ul class="flex flex-col gap-2.5">
            <li>
              <a href="/about" class="text-muted hover:text-ink text-[14px] transition-colors">About Us</a>
            </li>
            <li>
              <a href="/contact" class="text-muted hover:text-ink text-[14px] transition-colors">Contact Support</a>
            </li>
            <li>
              <a href="/privacy" class="text-muted hover:text-ink text-[14px] transition-colors">Privacy Policy</a>
            </li>
          </ul>
        </div>
      </div>

      <div class="max-w-[1280px] mx-auto px-6 border-t border-hairline mt-12 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-muted text-[13px]">
        <p>&copy; {new Date().getFullYear()} isitkitchensafe.com. All rights reserved.</p>
        <p class="text-[12px] italic text-center sm:text-right max-w-md">
          Disclaimer: The safety guidelines provided on this website are for informational purposes only. Always consult your appliance's manufacturer manual.
        </p>
      </div>
    </footer>

    <!-- Client-side navigation toggle -->
    <script is:inline>
      const toggleBtn = document.getElementById('mobile-menu-toggle');
      const closeBtn = document.getElementById('mobile-menu-close');
      const mobileMenu = document.getElementById('mobile-menu');

      if (toggleBtn && mobileMenu) {
        toggleBtn.addEventListener('click', () => {
          mobileMenu.classList.remove('translate-x-full');
        });
      }

      if (closeBtn && mobileMenu) {
        closeBtn.addEventListener('click', () => {
          mobileMenu.classList.add('translate-x-full');
        });
      }
    </script>
  </body>
</html>
