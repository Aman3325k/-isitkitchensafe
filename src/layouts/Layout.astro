---
import '../styles/global.css';
import { getLatestDataModifiedTime } from '../utils/materialCategories';

interface Props {
  title: string;
  description: string;
  faqs?: Array<{ question: string; answer: string }>;
  excludeArticleSchema?: boolean;
  excludeFaqSchema?: boolean;
  excludeBreadcrumbSchema?: boolean;
}

const { 
  title, 
  description, 
  faqs, 
  excludeArticleSchema = false,
  excludeFaqSchema = false,
  excludeBreadcrumbSchema = false
} = Astro.props;

// Auto-generate canonical URL
const canonicalUrl = new URL(Astro.url.pathname, 'https://isitkitchensafe.com').href.replace(/\/$/, '');

// Helper to format appliance and path names
function formatAppliance(app: string) {
  if (app === 'airfryer') return 'Air Fryer';
  if (app === 'how-long') return 'Shelf Life';
  if (app === 'washing-machine') return 'Washing Machine';
  if (app === 'refreeze') return 'Refreeze Safety';
  if (app === 'what-happens') return 'What Happens If';
  return app.charAt(0).toUpperCase() + app.slice(1);
}

// Generate FAQ JSON-LD Schema
const defaultFaqs = [
  {
    question: "How do you check if kitchenware is appliance safe?",
    answer: "Look for manufacturer stamps on the bottom of the item (such as a microwave wave symbol or dishwasher safe symbol), or consult the manufacturer manual."
  },
  {
    question: "What makes an item unsafe for kitchen appliances?",
    answer: "Unsafe materials typically react to heat, moisture, or waves, leading to warping, melting, cracking, rust, or the release of toxic chemical fumes."
  },
  {
    question: "Where can I find official appliance safety guidelines?",
    answer: "Official guidelines are published by government agencies like the USDA and FDA, as well as the appliance manufacturers themselves."
  }
];

const finalFaqs = faqs && faqs.length > 0 ? faqs : defaultFaqs;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": finalFaqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};

// Generate Article JSON-LD Schema
const lastModifiedIso = getLatestDataModifiedTime().toISOString();

// Generate BreadcrumbList JSON-LD Schema
const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const breadcrumbItems = [
  {
    "@type": "ListItem",
    "position": 1,
    "name": "Home",
    "item": "https://isitkitchensafe.com"
  }
];

if (pathSegments.length > 0) {
  const isAppliancePage = pathSegments.length === 1;
  const isItemPage = pathSegments.length === 2;
  
  if (isAppliancePage || isItemPage) {
    const appSlug = pathSegments[0];
    const appName = formatAppliance(appSlug);
    breadcrumbItems.push({
      "@type": "ListItem",
      "position": 2,
      "name": appName,
      "item": `https://isitkitchensafe.com/${appSlug}`
    });
  } else {
    const pageName = formatAppliance(pathSegments[0]);
    breadcrumbItems.push({
      "@type": "ListItem",
      "position": 2,
      "name": pageName,
      "item": `https://isitkitchensafe.com/${pathSegments[0]}`
    });
  }
  
  if (isItemPage) {
    const itemSlug = pathSegments[1];
    const itemName = itemSlug.split('-').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ');
    breadcrumbItems.push({
      "@type": "ListItem",
      "position": 3,
      "name": itemName,
      "item": `https://isitkitchensafe.com/${pathSegments[0]}/${itemSlug}`
    });
  }
}

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbItems
};

// Generate Article JSON-LD Schema
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title.split(' | ')[0],
  "description": description,
  "image": "https://isitkitchensafe.com/favicon.svg",
  "author": {
    "@type": "Organization",
    "name": "IsItKitchenSafe",
    "url": "https://isitkitchensafe.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "IsItKitchenSafe",
    "logo": {
      "@type": "ImageObject",
      "url": "https://isitkitchensafe.com/favicon.svg"
    }
  },
  "datePublished": "2026-06-13T12:00:00Z",
  "dateModified": lastModifiedIso,
  "mainEntityOfPage": canonicalUrl
};

const appliances = [
  { name: 'Dishwasher', slug: 'dishwasher' },
  { name: 'Microwave', slug: 'microwave' },
  { name: 'Freezer', slug: 'freezer' },
  { name: 'Oven', slug: 'oven' },
  { name: 'Dryer', slug: 'dryer' },
  { name: 'Air Fryer', slug: 'airfryer' },
  { name: 'Refrigerator', slug: 'refrigerator' }
];
---

<!doctype html>
<html lang="en">
  <head>
    <script is:inline>
      (function() {
        const theme = localStorage.getItem('theme');
        if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>
    <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin />
    <link rel="preconnect" href="https://www.google-analytics.com" crossorigin />
    {import.meta.env.PROD && (
      <script is:inline>
        (function() {
          function loadGA4() {
            var scriptEl = document.createElement('script');
            scriptEl.async = true;
            scriptEl.src = 'https://www.googletagmanager.com/gtag/js?id=G-Y4Z027NV2C';
            document.head.appendChild(scriptEl);

            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', 'G-Y4Z027NV2C');
          }

          var consent = localStorage.getItem('cookie-consent');
          if (consent === 'accepted') {
            loadGA4();
          } else if (!consent) {
            window.addEventListener('cookie-consent-accepted', function() {
              loadGA4();
            });
          }
        })();
      </script>
    )}
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#181d26" />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='20' fill='%23181d26'/><text y='75' font-size='70' x='15' fill='white'>✓</text></svg>">
    <meta name="generator" content={Astro.generator} />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://isitkitchensafe.com/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Is It Kitchen Safe - Kitchen Safety Reference Guides" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://isitkitchensafe.com/og-image.png" />

    {!excludeFaqSchema && faqSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    )}
    {!excludeBreadcrumbSchema && breadcrumbSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    )}
    {!excludeArticleSchema && articleSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    )}

    <!-- Dynamic Slot for Page-Specific Head Content -->
    <slot name="head" />
  </head>
  <body class="bg-canvas text-body font-sans selection:bg-signature-cream selection:text-ink min-h-screen flex flex-col">
    <!-- Header -->
    <header class="h-[64px] border-b border-hairline bg-canvas sticky top-0 z-50">
      <div class="max-w-[1280px] mx-auto px-6 h-full flex items-center justify-between gap-4">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2 group shrink-0" id="site-logo">
          <span class="w-8 h-8 rounded-lg bg-primary flex items-center justify-center text-on-primary font-display font-medium text-lg transition-transform group-active:scale-95">✓</span>
          <span class="text-ink font-display font-medium text-[16px] md:text-[18px] tracking-tight">Is It Kitchen Safe?</span>
        </a>

        <!-- Global Search Bar in Header -->
        <form id="global-search-form" class="relative flex-grow max-w-[200px] sm:max-w-[280px] mx-2">
          <input 
            type="text" 
            id="global-search-input" 
            placeholder="Search safety guides..." 
            list="global-search-items"
            autocomplete="off"
            aria-label="Search safety guides"
            class="w-full h-9 pl-3 pr-8 py-1.5 bg-canvas text-ink text-[13px] border border-hairline rounded-sm focus:outline-none focus:border-info-border"
          />
          <datalist id="global-search-items"></datalist>
          <div id="global-search-loading" class="hidden absolute right-2.5 top-1/2 -translate-y-1/2">
            <svg class="animate-spin h-3.5 w-3.5 text-muted" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
          </div>
        </form>

        <!-- Desktop Navigation -->
        <nav class="hidden xl:flex items-center gap-4 shrink-0" id="desktop-nav">
          <div class="flex items-center gap-3 border-r border-hairline pr-3">
            {appliances.map(app => (
              <a 
                href={`/${app.slug}`} 
                class="text-body hover:text-ink text-[13px] font-normal transition-colors"
              >
                {app.name}
              </a>
            ))}
          </div>
          <div class="flex items-center gap-3 pr-2">
            <a href="/compare" class="text-body hover:text-ink text-[13px] font-normal transition-colors">Compare</a>
            <a href="/material" class="text-body hover:text-ink text-[13px] font-normal transition-colors">Materials</a>
            <a href="/how-long" class="text-body hover:text-ink text-[13px] font-normal transition-colors">Shelf Life</a>
            <a href="/washing-machine" class="text-body hover:text-ink text-[13px] font-normal transition-colors">Washing</a>
            <a href="/refreeze" class="text-body hover:text-ink text-[13px] font-normal transition-colors">Refreezing</a>
            <a href="/what-happens" class="text-body hover:text-ink text-[13px] font-normal transition-colors">What Happens</a>
          </div>
          <a href="/about" class="text-muted hover:text-ink text-[13px] font-normal transition-colors border-l border-hairline pl-3">About</a>
        </nav>

        <!-- Theme Toggle Button -->
        <button
          type="button"
          id="theme-toggle"
          class="p-2 text-ink hover:bg-surface-soft rounded-md active:scale-95 transition-all cursor-pointer shrink-0"
          aria-label="Toggle Dark Mode"
        >
          <!-- Sun Icon (visible in dark mode) -->
          <svg id="theme-toggle-light-icon" class="w-5 h-5 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m0-12.728l.707.707m12.728 12.728l.707.707M12 8a4 4 0 100 8 4 4 0 000-8z" />
          </svg>
          <!-- Moon Icon (visible in light mode) -->
          <svg id="theme-toggle-dark-icon" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
          </svg>
        </button>

        <!-- Mobile Menu Toggle Button -->
        <button 
          type="button"
          id="mobile-menu-toggle"
          class="xl:hidden p-2 text-ink hover:bg-surface-soft rounded-md active:scale-95 transition-transform shrink-0"
          aria-label="Toggle Menu"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </header>

    <!-- Mobile Navigation Panel -->
    <div 
      id="mobile-menu"
      class="fixed inset-0 bg-canvas z-60 transform translate-x-full transition-transform duration-300 xl:hidden flex flex-col pt-16 px-6 overflow-y-auto pb-8"
    >
      <button 
        type="button"
        id="mobile-menu-close"
        class="absolute top-4 right-6 p-2 text-ink hover:bg-surface-soft rounded-md"
        aria-label="Close Menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
      <nav class="flex flex-col gap-4 text-center mt-6">
        <span class="text-xs uppercase tracking-wider text-muted font-bold block mb-1">Appliances</span>
        <div class="grid grid-cols-2 gap-2 mb-4">
          {appliances.map(app => (
            <a 
              href={`/${app.slug}`} 
              class="text-ink font-display font-medium text-sm py-2 bg-surface-soft active:bg-surface-strong rounded-md transition-colors"
            >
              {app.name}
            </a>
          ))}
        </div>

        <div class="border-t border-hairline my-2"></div>
        <span class="text-xs uppercase tracking-wider text-muted font-bold block mb-1">Categories</span>
        <div class="grid grid-cols-2 gap-2 mb-4">
          <a href="/compare" class="text-ink font-display font-medium text-sm py-2 bg-surface-soft active:bg-surface-strong rounded-md transition-colors col-span-2">Compare Guides</a>
          <a href="/material" class="text-ink font-display font-medium text-sm py-2 bg-surface-soft active:bg-surface-strong rounded-md transition-colors col-span-2">Material Directories</a>
          <a href="/how-long" class="text-ink font-display font-medium text-sm py-2 bg-surface-soft active:bg-surface-strong rounded-md transition-colors">Shelf Life</a>
          <a href="/washing-machine" class="text-ink font-display font-medium text-sm py-2 bg-surface-soft active:bg-surface-strong rounded-md transition-colors">Washing</a>
          <a href="/refreeze" class="text-ink font-display font-medium text-sm py-2 bg-surface-soft active:bg-surface-strong rounded-md transition-colors">Refreeze Safety</a>
          <a href="/what-happens" class="text-ink font-display font-medium text-sm py-2 bg-surface-soft active:bg-surface-strong rounded-md transition-colors">What Happens</a>
        </div>

        <div class="border-t border-hairline my-2"></div>
        <a href="/about" class="text-body font-normal py-2 active:bg-surface-soft rounded-md transition-colors">About Us</a>
        <a href="/contact" class="text-body font-normal py-2 active:bg-surface-soft rounded-md transition-colors">Contact</a>
        <a href="/privacy" class="text-body font-normal py-2 active:bg-surface-soft rounded-md transition-colors">Privacy Policy</a>
      </nav>
    </div>

    <!-- Main Content -->
    <main class="flex-grow">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-canvas border-t border-hairline py-[64px]" id="site-footer">
      <div class="max-w-[1280px] mx-auto px-6 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
        <div class="flex flex-col gap-4">
          <div class="flex items-center gap-2">
            <span class="w-6 h-6 rounded-md bg-primary flex items-center justify-center text-on-primary font-display font-medium text-sm">✓</span>
            <span class="text-ink font-display font-medium text-[16px] tracking-tight">Is It Kitchen Safe?</span>
          </div>
          <p class="text-muted text-[13px] leading-relaxed max-w-sm">
            Quick, reliable safety guides for kitchen appliances. Find out whether you can put food containers, cookware, or utensils in the microwave, dishwasher, freezer, and more.
          </p>
        </div>

        <div>
          <h3 class="text-ink font-semibold text-[14px] uppercase tracking-wider mb-4">Appliance Guides</h3>
          <ul class="flex flex-col gap-2.5">
            {appliances.map(app => (
              <li>
                <a href={`/${app.slug}`} class="text-muted hover:text-ink text-[14px] transition-colors">{app.name} Guides</a>
              </li>
            ))}
          </ul>
        </div>

        <div>
          <h3 class="text-ink font-semibold text-[14px] uppercase tracking-wider mb-4">Safety Directories</h3>
          <ul class="flex flex-col gap-2.5">
            <li>
              <a href="/material" class="text-muted hover:text-ink text-[14px] transition-colors">Material Safety Hubs</a>
            </li>
            <li>
              <a href="/how-long" class="text-muted hover:text-ink text-[14px] transition-colors">Shelf Life & Storage</a>
            </li>
            <li>
              <a href="/refreeze" class="text-muted hover:text-ink text-[14px] transition-colors">Refreezing Safety</a>
            </li>
            <li>
              <a href="/washing-machine" class="text-muted hover:text-ink text-[14px] transition-colors">Washing Machine</a>
            </li>
            <li>
              <a href="/what-happens" class="text-muted hover:text-ink text-[14px] transition-colors">Emergency Scenarios</a>
            </li>
          </ul>
        </div>

        <div>
          <h3 class="text-ink font-semibold text-[14px] uppercase tracking-wider mb-4">Resources & Legal</h3>
          <ul class="flex flex-col gap-2.5">
            <li>
              <a href="/blog" class="text-muted hover:text-ink text-[14px] transition-colors font-medium">Kitchen Safety Blog</a>
            </li>
            <li>
              <a href="/compare" class="text-muted hover:text-ink text-[14px] transition-colors font-medium font-display">Safety Comparisons</a>
            </li>
            <li>
              <a href="/sitemap-page" class="text-muted hover:text-ink text-[14px] transition-colors">HTML Sitemap</a>
            </li>
            <li>
              <a href="/about" class="text-muted hover:text-ink text-[14px] transition-colors">About Us</a>
            </li>
            <li>
              <a href="/contact" class="text-muted hover:text-ink text-[14px] transition-colors">Contact Support</a>
            </li>
            <li>
              <a href="/privacy" class="text-muted hover:text-ink text-[14px] transition-colors">Privacy Policy</a>
            </li>
            <li>
              <a href="/terms" class="text-muted hover:text-ink text-[14px] transition-colors">Terms & Conditions</a>
            </li>
          </ul>
        </div>
      </div>

      <div class="max-w-[1280px] mx-auto px-6 border-t border-hairline mt-12 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-muted text-[13px]">
        <p>&copy; {new Date().getFullYear()} isitkitchensafe.com. All rights reserved.</p>
        <p class="text-[12px] italic text-center sm:text-right max-w-md">
          Disclaimer: The safety guidelines provided on this website are for informational purposes only. Always consult your appliance's manufacturer manual.
        </p>
      </div>
    </footer>

    <!-- Client-side navigation toggle and global search index load -->
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const toggleBtn = document.getElementById('mobile-menu-toggle');
        const closeBtn = document.getElementById('mobile-menu-close');
        const mobileMenu = document.getElementById('mobile-menu');

        if (toggleBtn && mobileMenu) {
          toggleBtn.addEventListener('click', () => {
            mobileMenu.classList.remove('translate-x-full');
          });
        }

        if (closeBtn && mobileMenu) {
          closeBtn.addEventListener('click', () => {
            mobileMenu.classList.add('translate-x-full');
          });
        }

        // Dark mode toggle logic
        const themeToggleBtn = document.getElementById('theme-toggle');
        const themeToggleDarkIcon = document.getElementById('theme-toggle-dark-icon');
        const themeToggleLightIcon = document.getElementById('theme-toggle-light-icon');

        const updateIcons = () => {
          if (document.documentElement.classList.contains('dark')) {
            themeToggleDarkIcon?.classList.add('hidden');
            themeToggleLightIcon?.classList.remove('hidden');
          } else {
            themeToggleDarkIcon?.classList.remove('hidden');
            themeToggleLightIcon?.classList.add('hidden');
          }
        };

        updateIcons();

        if (themeToggleBtn) {
          themeToggleBtn.addEventListener('click', () => {
            if (document.documentElement.classList.contains('dark')) {
              document.documentElement.classList.remove('dark');
              localStorage.setItem('theme', 'light');
            } else {
              document.documentElement.classList.add('dark');
              localStorage.setItem('theme', 'dark');
            }
            updateIcons();
          });
        }

        const searchForm = document.getElementById('global-search-form') as HTMLFormElement | null;
        const searchInput = document.getElementById('global-search-input') as HTMLInputElement | null;
        const datalist = document.getElementById('global-search-items') as HTMLDataListElement | null;
        const searchLoading = document.getElementById('global-search-loading');
        let searchIndex: Array<{ name: string; category: string; url: string }> | null = null;
        let isFetching = false;

        const populateDatalist = (items: typeof searchIndex) => {
          if (!datalist || !items) return;
          datalist.innerHTML = items.map(entry => 
            `<option value="${entry.name} (${entry.category})" data-url="${entry.url}"></option>`
          ).join('');
        };

        const loadSearchIndex = async () => {
          if (searchIndex || isFetching) return;
          isFetching = true;
          if (searchLoading) searchLoading.classList.remove('hidden');
          try {
            const response = await fetch('/search-index.json');
            if (response.ok) {
              searchIndex = await response.json();
              populateDatalist(searchIndex);
            }
          } catch (e) {
            // Silently fail to maintain UX
          } finally {
            isFetching = false;
            if (searchLoading) searchLoading.classList.add('hidden');
          }
        };

        if (searchInput) {
          searchInput.addEventListener('focus', loadSearchIndex);
          searchInput.addEventListener('input', loadSearchIndex);
        }

        if (searchForm && searchInput) {
          searchForm.addEventListener('submit', (e) => {
            e.preventDefault();
            const rawValue = searchInput.value.trim().toLowerCase();
            if (!rawValue || !searchIndex) return;

            let match = searchIndex.find(item => item.name.toLowerCase() === rawValue);

            if (!match) {
              match = searchIndex.find(item => {
                const displayVal = `${item.name} (${item.category})`.toLowerCase();
                return displayVal === rawValue;
              });
            }

            if (!match) {
              match = searchIndex.find(item => item.name.toLowerCase().includes(rawValue));
            }

            if (!match) {
              const categoryMap: Record<string, string> = {
                'dishwasher': '/dishwasher',
                'microwave': '/microwave',
                'freezer': '/freezer',
                'oven': '/oven',
                'dryer': '/dryer',
                'air fryer': '/airfryer',
                'airfryer': '/airfryer',
                'refrigerator': '/refrigerator',
                'fridge': '/refrigerator',
                'shelf life': '/how-long',
                'how long': '/how-long',
                'washing machine': '/washing-machine',
                'refreeze': '/refreeze',
                'what happens': '/what-happens',
                'compare': '/compare',
                'comparison': '/compare',
                'comparisons': '/compare'
              };
              if (categoryMap[rawValue]) {
                window.location.href = categoryMap[rawValue];
                return;
              }
            }

            if (match) {
              window.location.href = match.url;
            } else {
              alert(`No direct match found for "${searchInput.value}". Please use the suggestions list or check spelling.`);
            }
          });
        }
      });
    </script>

    <!-- Cookie Consent Banner -->
    <div id="cookie-consent-banner" class="fixed bottom-4 left-4 right-4 md:left-auto md:max-w-md bg-canvas border border-hairline shadow-lg rounded-lg p-6 z-[100] hidden transition-all duration-300 transform translate-y-4 opacity-0">
      <h3 class="text-title-sm text-ink font-semibold mb-2">🍪 Cookie Consent</h3>
      <p class="text-[13px] text-body mb-4 leading-relaxed">
        We use cookies to analyze website traffic and optimize your site experience. By clicking "Accept", you agree to our use of cookies as described in our <a href="/privacy" class="text-link hover:underline">Privacy Policy</a>.
      </p>
      <div class="flex justify-end gap-3 text-xs">
        <button id="cookie-decline-btn" class="px-4 py-2 bg-canvas text-ink border border-hairline rounded-md hover:bg-surface-soft cursor-pointer transition-colors font-medium">
          Decline
        </button>
        <button id="cookie-accept-btn" class="px-4 py-2 bg-primary text-on-primary rounded-md hover:bg-primary-active cursor-pointer transition-colors font-medium">
          Accept
        </button>
      </div>
    </div>

    <script is:inline>
      (function() {
        function initCookieConsent() {
          var banner = document.getElementById('cookie-consent-banner');
          var acceptBtn = document.getElementById('cookie-accept-btn');
          var declineBtn = document.getElementById('cookie-decline-btn');

          if (!banner || !acceptBtn || !declineBtn) return;

          var consent = localStorage.getItem('cookie-consent');

          if (!consent) {
            // Show the banner with a slight delay for smooth animation
            setTimeout(function() {
              banner.classList.remove('hidden');
              // Force reflow
              banner.offsetHeight;
              banner.classList.remove('translate-y-4', 'opacity-0');
              banner.classList.add('translate-y-0', 'opacity-100');
            }, 800);
          }

          acceptBtn.addEventListener('click', function() {
            localStorage.setItem('cookie-consent', 'accepted');
            hideBanner();
            window.dispatchEvent(new CustomEvent('cookie-consent-accepted'));
          });

          declineBtn.addEventListener('click', function() {
            localStorage.setItem('cookie-consent', 'declined');
            hideBanner();
          });

          function hideBanner() {
            banner.classList.remove('translate-y-0', 'opacity-100');
            banner.classList.add('translate-y-4', 'opacity-0');
            setTimeout(function() {
              banner.classList.add('hidden');
            }, 300);
          }
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initCookieConsent);
        } else {
          initCookieConsent();
        }
      })();
    </script>
  </body>
</html>
