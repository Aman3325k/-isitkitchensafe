---
import Layout from '../layouts/Layout.astro';

const pageTitle = "Contact Us | IsItKitchenSafe";
const pageDescription = "Have questions, corrections, or suggestions for our kitchen safety guides? Send us a message and our editorial team will get back to you as soon as possible.";

const contactFaqs = [
  {
    question: "How can I suggest a new item to be reviewed?",
    answer: "You can suggest new items by filling out our contact form or emailing us directly at support@isitkitchensafe.com."
  },
  {
    question: "How long does it take to get a response?",
    answer: "Our team typically reviews all suggestions and corrections within 2 to 3 business days."
  }
];
---

<Layout title={pageTitle} description={pageDescription} faqs={contactFaqs} excludeArticleSchema={true}>
  <section class="max-w-[600px] mx-auto px-6 py-[96px]">
    <h1 class="text-display-lg font-medium text-ink tracking-tight mb-4">Contact Us</h1>
    <p class="text-body-md text-muted mb-8 leading-relaxed">
      Have a suggestion for a kitchen item we haven't covered yet? Found a correction for one of our safety guides? Fill out the form below or email us directly at <a href="mailto:support@isitkitchensafe.com" class="text-link hover:underline">support@isitkitchensafe.com</a>.
    </p>

    <!-- Client-side Interactive Form -->
    <form id="contact-form" class="flex flex-col gap-6">
      <div class="flex flex-col gap-2">
        <label for="name" class="text-[13px] font-semibold text-ink uppercase tracking-wider">Your Name</label>
        <input 
          type="text" 
          id="name" 
          name="name" 
          required 
          placeholder="Jane Doe"
          class="w-full h-11 px-4 py-3 bg-canvas text-ink text-[14px] border border-hairline rounded-sm focus:outline-none focus:border-info-border"
        />
      </div>

      <div class="flex flex-col gap-2">
        <label for="email" class="text-[13px] font-semibold text-ink uppercase tracking-wider">Email Address</label>
        <input 
          type="email" 
          id="email" 
          name="email" 
          required 
          placeholder="jane@example.com"
          class="w-full h-11 px-4 py-3 bg-canvas text-ink text-[14px] border border-hairline rounded-sm focus:outline-none focus:border-info-border"
        />
      </div>

      <div class="flex flex-col gap-2">
        <label for="subject" class="text-[13px] font-semibold text-ink uppercase tracking-wider">Subject</label>
        <input 
          type="text" 
          id="subject" 
          name="subject" 
          required 
          placeholder="New Item Suggestion / Guide Correction"
          class="w-full h-11 px-4 py-3 bg-canvas text-ink text-[14px] border border-hairline rounded-sm focus:outline-none focus:border-info-border"
        />
      </div>

      <div class="flex flex-col gap-2">
        <label for="message" class="text-[13px] font-semibold text-ink uppercase tracking-wider">Message</label>
        <textarea 
          id="message" 
          name="message" 
          required 
          rows="5"
          placeholder="Tell us about the kitchen item and appliance..."
          class="w-full px-4 py-3 bg-canvas text-ink text-[14px] border border-hairline rounded-sm focus:outline-none focus:border-info-border resize-y min-h-[120px]"
        ></textarea>
      </div>

      <button 
        type="submit" 
        class="btn-primary mt-2"
      >
        Send Message
      </button>
    </form>

    <!-- Success Message Container -->
    <div id="success-message" class="hidden bg-[#f4faf6] border border-[#39bf45]/30 rounded-md p-6 mt-8">
      <h3 class="text-title-sm text-success font-medium mb-2 flex items-center gap-1.5">
        <span>✓</span> Message Sent!
      </h3>
      <p class="text-[13px] text-body leading-relaxed">
        Thank you for reaching out. We have received your inquiry and will review it as soon as possible.
      </p>
    </div>
  </section>

  <script is:inline>
    const form = document.getElementById('contact-form');
    const successMsg = document.getElementById('success-message');

    if (form && successMsg) {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        
        // Hide the form and show the success message
        form.classList.add('hidden');
        successMsg.classList.remove('hidden');
        
        // Optionally scroll to success message
        successMsg.scrollIntoView({ behavior: 'smooth' });
      });
    }
  </script>
</Layout>
