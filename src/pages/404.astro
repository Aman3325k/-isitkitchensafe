---
import Layout from '../layouts/Layout.astro';
import itemsData from '../data/items.json';

const pageTitle = "404 - Page Not Found | IsItKitchenSafe";
const pageDescription = "Sorry, we could not find the kitchen safety guide you were looking for. Search our database or explore popular categories and guides to find answers quickly.";

// 10 popular items/queries with exact urls
const popularGuides = [
  { name: "Hydro Flask in Dishwasher", url: "/dishwasher/hydroflask" },
  { name: "Styrofoam in Microwave", url: "/microwave/styrofoam" },
  { name: "Cast Iron in Dishwasher", url: "/dishwasher/cast-iron" },
  { name: "Parchment Paper in Air Fryer", url: "/airfryer/parchment-paper-airfryer" },
  { name: "Crocs in Dryer", url: "/dryer/crocs" },
  { name: "Avocado in Freezer", url: "/freezer/avocado" },
  { name: "Refreezing Thawed Chicken", url: "/refreeze/chicken" },
  { name: "Aluminum Foil in Microwave", url: "/what-happens/microwave-aluminum-foil" },
  { name: "Wooden Spoons in Dishwasher", url: "/dishwasher/wooden-spoon" },
  { name: "Boiling Eggs in Microwave", url: "/what-happens/microwave-egg-in-shell" }
];

const categories = [
  { name: "Dishwasher Safety", url: "/dishwasher", color: "bg-signature-forest text-on-primary" },
  { name: "Microwave Safety", url: "/microwave", color: "bg-signature-coral text-on-primary" },
  { name: "Freezer Storage", url: "/freezer", color: "bg-signature-cream text-ink" },
  { name: "Oven Safety", url: "/oven", color: "bg-signature-peach text-ink" },
  { name: "Air Fryer Rules", url: "/airfryer", color: "bg-signature-yellow text-ink" }
];
---

<Layout title={pageTitle} description={pageDescription}>
  <section class="max-w-[800px] mx-auto px-6 py-16 text-center flex flex-col items-center justify-center min-h-[70vh]">
    <!-- Icon/Badge -->
    <div class="w-16 h-16 rounded-full bg-signature-cream border border-signature-peach flex items-center justify-center text-3xl mb-6 select-none" aria-hidden="true">
      🍳
    </div>

    <!-- H1 Heading -->
    <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-ink mb-4">
      404 - Safety Guide Not Found
    </h1>
    <p class="text-body-md text-muted max-w-[540px] mb-10 leading-relaxed">
      Oops! The page you are looking for doesn't exist, was moved, or has been taken out of the kitchen. Try searching our database or checking out these popular guides.
    </p>

    <!-- Search Box for 404 -->
    <div class="w-full max-w-[500px] mb-12">
      <form id="404-search-form" class="flex flex-col sm:flex-row gap-3">
        <input 
          type="text" 
          id="404-search-input" 
          placeholder="Search safety guides (e.g. foil, butter, crocs)..." 
          autocomplete="off"
          aria-label="Search safety guides"
          class="flex-grow h-11 px-4 py-3 bg-canvas text-ink text-[14px] border border-hairline rounded-sm focus:outline-none focus:border-info-border"
        />
        <button 
          type="submit" 
          class="h-11 px-6 bg-primary hover:bg-primary-active text-on-primary text-[14px] font-medium rounded-sm border-none cursor-pointer flex items-center justify-center transition-colors select-none shrink-0"
        >
          Search
        </button>
      </form>
    </div>

    <!-- Category Shortcuts -->
    <div class="w-full mb-12">
      <h2 class="text-xs uppercase tracking-wider text-muted font-bold mb-4">Browse Our Safety Categories</h2>
      <div class="flex flex-wrap justify-center gap-3">
        {categories.map(cat => (
          <a 
            href={cat.url} 
            class={`${cat.color} px-4 py-2 rounded-md text-[13px] font-medium shadow-xs hover:opacity-90 transition-opacity active:scale-[0.98] border border-hairline/25`}
          >
            {cat.name}
          </a>
        ))}
      </div>
    </div>

    <!-- 10 Popular Items -->
    <div class="w-full max-w-[600px] mb-12 text-left bg-surface-soft border border-hairline p-6 rounded-lg">
      <h2 class="text-title-sm text-ink font-semibold mb-4 text-center">Top 10 Most Searched Safety Guides</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-2.5">
        {popularGuides.map(guide => (
          <a 
            href={guide.url} 
            class="text-[13px] text-link hover:underline flex items-center gap-1.5"
          >
            <span class="text-success">&bull;</span> {guide.name}
          </a>
        ))}
      </div>
    </div>

    <!-- Action Buttons -->
    <div class="flex flex-col sm:flex-row gap-4">
      <a href="/" class="btn-primary">
        Back to Homepage
      </a>
      <a href="/blog" class="btn-secondary">
        Read Safety Blog
      </a>
    </div>
  </section>

  <!-- Script for 404 search redirect -->
  <script>
    const searchForm = document.getElementById('404-search-form');
    const searchInput = document.getElementById('404-search-input');

    if (searchForm && searchInput) {
      searchForm.addEventListener('submit', (e) => {
        e.preventDefault();
        const query = (searchInput as HTMLInputElement).value.trim();
        if (!query) return;

        // Redirect to homepage search query
        window.location.href = `/?q=${encodeURIComponent(query)}`;
      });
    }
  </script>
</Layout>
