---
import Layout from '../../layouts/Layout.astro';
import refreezeData from '../../data/refreeze.json';

const pageTitle = "Refreeze Safety & Guidelines | IsItKitchenSafe";
const pageDescription = "Explore refreezing food safety guidelines. Find out whether raw chicken, ground beef, milk, cheese, bread, or cooked leftovers can be refrozen after thawing.";

const indexFaqs = [
  {
    question: "Is it safe to refreeze food that has thawed?",
    answer: "Yes, raw or cooked foods thawed in the refrigerator can be refrozen safely. Foods left out of the refrigerator for more than two hours should not be refrozen."
  },
  {
    question: "Does refreezing ruin food quality?",
    answer: "Refreezing can degrade food texture, moisture, and flavor because cell structures expand and lose water during thawing. It remains pathogen-safe if kept cold."
  }
];
---

<Layout title={pageTitle} description={pageDescription} faqs={indexFaqs}>
  <!-- Hero Section -->
  <section class="bg-signature-cream text-ink py-[64px] md:py-[80px]">
    <div class="max-w-[1280px] mx-auto px-6">
      <nav class="flex gap-2 text-[13px] text-muted mb-6" aria-label="Breadcrumb">
        <a href="/" class="hover:underline">Home</a>
        <span>/</span>
        <span class="font-medium text-ink">Refreeze Safety</span>
      </nav>
      
      <h1 class="text-display-lg font-medium tracking-tight mb-4">
        Refreeze Safety Guides
      </h1>
      <p class="text-muted text-body-md max-w-2xl leading-relaxed">
        Search and browse safety guidelines for refreezing meat, poultry, dairy, produce, and cooked meals. Prevent bacterial growth and food safety hazards.
      </p>
    </div>
  </section>

  <!-- Items Grid Section -->
  <section class="max-w-[1280px] mx-auto px-6 py-[96px]">
    <div class="flex flex-col md:flex-row md:items-end justify-between border-b border-hairline pb-8 mb-12">
      <div>
        <h2 class="text-display-md text-ink tracking-tight mb-2">Tested Items ({refreezeData.length})</h2>
        <p class="text-body-md text-muted">Complete USDA-aligned refreezing evaluations for raw and cooked items.</p>
      </div>
      
      <!-- Filter Input -->
      <div class="mt-6 md:mt-0 flex gap-3 max-w-[320px] w-full">
        <input 
          type="text" 
          id="filter-input"
          placeholder="Search items (e.g. chicken)..."
          class="w-full h-10 px-3 py-2 bg-canvas text-ink text-[14px] border border-hairline rounded-sm focus:outline-none focus:border-info-border"
        />
      </div>
    </div>

    <!-- Items Grid -->
    <div id="items-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {refreezeData.map(item => (
        <div 
          class="item-card bg-canvas border border-hairline rounded-md p-6 flex flex-col justify-between shadow-xs transition-all hover:border-border-strong"
          data-name={item.item.toLowerCase()}
        >
          <div>
            <div class="flex items-center justify-between mb-4">
              <span class="text-caption text-muted uppercase tracking-wider text-xs">Refreeze Guide</span>
              {item.safe === 'yes' && <span class="badge-yes">YES</span>}
              {item.safe === 'no' && <span class="badge-no">NO</span>}
              {item.safe === 'depends' && <span class="badge-depends">DEPENDS</span>}
            </div>
            
            <h3 class="text-title-sm text-ink mb-3">
              Can You Put {item.item} in the Freezer?
            </h3>
            
            <p class="text-body-md text-body leading-relaxed mb-6">
              {item.shortAnswer}
            </p>
          </div>
          
          <a 
            href={`/refreeze/${item.slug}`} 
            class="text-link text-[14px] font-medium hover:text-link-active transition-colors flex items-center gap-1 group mt-4"
          >
            Read refreeze safety details <span class="group-hover:translate-x-0.5 transition-transform">&rarr;</span>
          </a>
        </div>
      ))}
    </div>

    <!-- No results message -->
    <div id="no-results" class="hidden text-center py-12">
      <p class="text-title-md text-muted">No items match your search.</p>
    </div>
  </section>

  <!-- Client-side filtering script -->
  <script is:inline>
    const filterInput = document.getElementById('filter-input');
    const itemsGrid = document.getElementById('items-grid');
    const noResults = document.getElementById('no-results');

    if (filterInput && itemsGrid) {
      const cards = itemsGrid.getElementsByClassName('item-card');
      
      filterInput.addEventListener('input', (e) => {
        const query = e.target.value.trim().toLowerCase();
        let matches = 0;
        
        for (let i = 0; i < cards.length; i++) {
          const card = cards[i];
          const name = card.getAttribute('data-name');
          
          if (name.includes(query)) {
            card.style.display = '';
            matches++;
          } else {
            card.style.display = 'none';
          }
        }
        
        if (matches === 0) {
          noResults.classList.remove('hidden');
        } else {
          noResults.classList.add('hidden');
        }
      });
    }
  </script>
</Layout>
