---
import Layout from '../../layouts/Layout.astro';
import comparisonsData from '../../data/comparisons.json';
import itemsData from '../../data/items.json';
import howLongData from '../../data/how-long.json';
import refreezeData from '../../data/refreeze.json';
import washingData from '../../data/washing-machine.json';
import { normalizeItemName } from '../../utils/linkingHelper.js';

export async function getStaticPaths() {
  return comparisonsData.map(item => ({
    params: { slug: item.slug },
    props: { comparison: item }
  }));
}

interface Props {
  comparison: typeof comparisonsData[number];
}

const { comparison } = Astro.props;
const {
  slug,
  category,
  item1,
  item2,
  winner,
  verdict,
  table,
  item1Pros,
  item2Pros,
  useCases,
  safetyNotes,
  faqs,
  relatedComparisons,
  relatedItems
} = comparison;

// Human-readable category names
const categoryNames: Record<string, string> = {
  "cooking-method": "Cooking Methods",
  "container-material": "Containers & Materials",
  "food-storage": "Food Storage",
  "appliance-safety": "Appliance Safety"
};

// Strictly generate 150-160 characters meta description containing the winner/depends
function getMetaDescription(i1: string, i2: string, win: string, verd: string) {
  let prefix = "";
  if (win === "item1") {
    prefix = `Is ${i1} or ${i2} better? Our safety guide names ${i1} the winner. `;
  } else if (win === "item2") {
    prefix = `Is ${i1} or ${i2} better? Our safety guide names ${i2} the winner. `;
  } else {
    prefix = `Is ${i1} or ${i2} better? Our kitchen safety comparison outlines when to use each. `;
  }
  
  let desc = `${prefix}${verd}`;
  
  if (desc.length < 150) {
    const suffix = " Read our detailed side-by-side comparison table, pros, and safety tips.";
    desc = (desc + suffix).substring(0, 160);
  }
  
  if (desc.length > 160) {
    desc = desc.substring(0, 157) + "...";
  }
  
  // Pad if still too short
  if (desc.length < 150) {
    desc = desc.padEnd(150, '.');
  }
  
  return desc;
}

const pageTitle = `${item1} vs ${item2}: Which Is Better? | IsItKitchenSafe`;
const pageDescription = getMetaDescription(item1, item2, winner, verdict);

// Find related comparison objects for linking (ensuring 4 related comparison pages)
let relatedComparisonObjects = comparisonsData.filter(c => 
  relatedComparisons.includes(c.slug) && c.slug !== slug
);
if (relatedComparisonObjects.length < 4) {
  const extraComps = comparisonsData.filter(c => 
    c.slug !== slug && !relatedComparisons.includes(c.slug)
  );
  for (const c of extraComps) {
    if (relatedComparisonObjects.length >= 4) break;
    relatedComparisonObjects.push(c);
  }
}
relatedComparisonObjects = relatedComparisonObjects.slice(0, 4);

// Format related item paths nicely
function formatItemLinkText(url: string) {
  const parts = url.split('/').filter(Boolean);
  if (parts.length < 2) return "Kitchen Safety Guide";
  const app = parts[0] === 'airfryer' ? 'Air Fryer' : parts[0].charAt(0).toUpperCase() + parts[0].slice(1);
  const itm = parts[1].split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
  return `${itm} in the ${app} Guide`;
}

// Resolve item1 and item2 URLs dynamically to guarantee they are linked
function resolveItemPageUrl(itemName: string) {
  const norm = normalizeItemName(itemName);
  const match = itemsData.find(i => normalizeItemName(i.item) === norm);
  if (match) return `/${match.appliance}/${match.slug}`;
  
  const hlMatch = howLongData.find(h => normalizeItemName(h.item) === norm);
  if (hlMatch) return `/how-long/${hlMatch.slug}`;
  
  const rfMatch = refreezeData.find(r => normalizeItemName(r.item) === norm);
  if (rfMatch) return `/refreeze/${rfMatch.slug}`;
  
  const wMatch = washingData.find(w => normalizeItemName(w.item) === norm);
  if (wMatch) return `/washing-machine/${wMatch.slug}`;
  
  return null;
}

const item1Url = resolveItemPageUrl(item1);
const item2Url = resolveItemPageUrl(item2);
const individualGuides: { name: string; url: string }[] = [];
if (item1Url) individualGuides.push({ name: item1, url: item1Url });
if (item2Url) individualGuides.push({ name: item2, url: item2Url });

if (relatedItems) {
  relatedItems.forEach(url => {
    if (!individualGuides.some(g => g.url === url)) {
      individualGuides.push({ name: formatItemLinkText(url), url });
    }
  });
}

// Find relevant how-long or refreeze guides for both items
const preservationGuides: { name: string; url: string; label: string }[] = [];
const addPreservationGuide = (name: string, url: string, label: string) => {
  if (!preservationGuides.some(g => g.url === url)) {
    preservationGuides.push({ name, url, label });
  }
};

const item1Norm = normalizeItemName(item1);
const item1Hl = howLongData.find(h => normalizeItemName(h.item) === item1Norm);
if (item1Hl) addPreservationGuide(`How Long Does ${item1Hl.item} Last?`, `/how-long/${item1Hl.slug}`, 'Shelf Life');
const item1Rf = refreezeData.find(r => normalizeItemName(r.item) === item1Norm);
if (item1Rf) addPreservationGuide(`Can You Refreeze ${item1Rf.item}?`, `/refreeze/${item1Rf.slug}`, 'Refreezing');

const item2Norm = normalizeItemName(item2);
const item2Hl = howLongData.find(h => normalizeItemName(h.item) === item2Norm);
if (item2Hl) addPreservationGuide(`How Long Does ${item2Hl.item} Last?`, `/how-long/${item2Hl.slug}`, 'Shelf Life');
const item2Rf = refreezeData.find(r => normalizeItemName(r.item) === item2Norm);
if (item2Rf) addPreservationGuide(`Can You Refreeze ${item2Rf.item}?`, `/refreeze/${item2Rf.slug}`, 'Refreezing');

// Schemas
const pageCanonical = `https://isitkitchensafe.com/compare/${slug}`;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://isitkitchensafe.com"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Compare",
      "item": "https://isitkitchensafe.com/compare"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": `${item1} vs ${item2}`,
      "item": pageCanonical
    }
  ]
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": `${item1} vs ${item2}: Which Is Better?`,
  "description": pageDescription,
  "image": "https://isitkitchensafe.com/favicon.svg",
  "author": {
    "@type": "Organization",
    "name": "IsItKitchenSafe",
    "url": "https://isitkitchensafe.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "IsItKitchenSafe",
    "logo": {
      "@type": "ImageObject",
      "url": "https://isitkitchensafe.com/favicon.svg"
    }
  },
  "datePublished": "2026-06-13T12:00:00Z",
  "dateModified": "2026-06-13T12:00:00Z",
  "mainEntityOfPage": pageCanonical
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};
---

<Layout title={pageTitle} description={pageDescription}>
  <!-- Inject Schemas into Head Slot -->
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <div class="bg-canvas py-8">
    <div class="max-w-[800px] mx-auto px-6">
      
      <!-- Breadcrumbs -->
      <nav class="flex gap-2 text-muted text-[13px] mb-6" aria-label="Breadcrumb">
        <a href="/" class="hover:text-ink transition-colors">Home</a>
        <span>/</span>
        <a href="/compare" class="hover:text-ink transition-colors">Compare</a>
        <span>/</span>
        <span class="text-ink font-medium">{item1} vs {item2}</span>
      </nav>

      <!-- H1 Page Header -->
      <header class="mb-8 border-b border-hairline pb-8">
        <span class="text-xs font-bold uppercase tracking-wider text-muted mb-2 block">
          {categoryNames[category]} Comparison
        </span>
        <h1 class="text-display-md md:text-display-lg font-medium text-ink tracking-tight mb-6 leading-tight">
          {item1} vs {item2}: Which Should You Use?
        </h1>

        <!-- Huge and Obvious Winner Badge above the fold -->
        <div class="flex items-center mb-6">
          {winner === "item1" && (
            <div class="inline-flex items-center gap-2 px-6 py-3 bg-green-50 border border-green-200 rounded-full text-green-700 text-lg md:text-xl font-bold font-display">
              <span class="text-2xl leading-none">✓</span>
              <span>{item1.toUpperCase()} WINS</span>
            </div>
          )}
          {winner === "item2" && (
            <div class="inline-flex items-center gap-2 px-6 py-3 bg-green-50 border border-green-200 rounded-full text-green-700 text-lg md:text-xl font-bold font-display">
              <span class="text-2xl leading-none">✓</span>
              <span>{item2.toUpperCase()} WINS</span>
            </div>
          )}
          {winner === "depends" && (
            <div class="inline-flex items-center gap-2 px-6 py-3 bg-gray-50 border border-gray-200 rounded-full text-gray-700 text-lg md:text-xl font-bold font-display">
              <span class="text-xl leading-none">⚠</span>
              <span>IT DEPENDS</span>
            </div>
          )}
        </div>

        <!-- Quick Verdict -->
        <div class="p-5 bg-surface-soft border-l-4 border-primary rounded-r-md">
          <p class="text-body-md text-ink text-[15px] leading-relaxed">
            <strong>{verdict}</strong>
          </p>
        </div>
      </header>

      <!-- Side-by-Side Comparison Table -->
      <section class="mb-12">
        <h2 class="text-title-lg font-bold text-ink mb-6">Side-by-Side Comparison</h2>
        
        <!-- Desktop Table (visible md and up) -->
        <div class="hidden md:block overflow-hidden border border-hairline rounded-lg">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-surface-soft border-b border-hairline">
                <th class="w-[20%] p-4 font-display font-medium text-ink text-[14px]">Aspect</th>
                <th class={`w-[40%] p-4 font-display font-medium text-[14px] text-center ${winner === 'item1' ? 'bg-green-50/50 border-l-2 border-green-500' : 'bg-gray-50/50'}`}>
                  {item1}
                </th>
                <th class={`w-[40%] p-4 font-display font-medium text-[14px] text-center ${winner === 'item2' ? 'bg-green-50/50 border-l-2 border-green-500' : 'bg-gray-50/50'}`}>
                  {item2}
                </th>
              </tr>
            </thead>
            <tbody class="divide-y divide-hairline">
              {table.map((row, idx) => (
                <tr class={idx % 2 === 0 ? 'bg-canvas' : 'bg-surface-soft/30'}>
                  <td class="p-4 font-medium text-ink text-[13px]">{row.aspect}</td>
                  
                  <!-- Item 1 Value Cell -->
                  <td class={`p-4 text-[13px] text-center ${winner === 'item1' ? 'bg-green-50 border-l-2 border-green-500 font-medium text-green-950' : 'bg-gray-50 text-muted'}`}>
                    {row.item1Value}
                  </td>
                  
                  <!-- Item 2 Value Cell -->
                  <td class={`p-4 text-[13px] text-center ${winner === 'item2' ? 'bg-green-50 border-l-2 border-green-500 font-medium text-green-950' : 'bg-gray-50 text-muted'}`}>
                    {row.item2Value}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <!-- Mobile Table Stacking (visible below md) -->
        <div class="block md:hidden flex flex-col gap-4">
          {table.map((row) => (
            <div class="border border-hairline rounded-lg overflow-hidden">
              <div class="bg-surface-soft px-4 py-2 text-ink font-bold text-[13px] border-b border-hairline">
                {row.aspect}
              </div>
              <div class="p-4 flex flex-col gap-3">
                <div class={`p-3 rounded-md ${winner === 'item1' ? 'bg-green-50 border-l-4 border-green-500' : 'bg-gray-50'}`}>
                  <span class="block text-[11px] font-bold text-muted uppercase mb-1">{item1}</span>
                  <span class={`text-[13px] ${winner === 'item1' ? 'text-green-950 font-medium' : 'text-body'}`}>{row.item1Value}</span>
                </div>
                <div class={`p-3 rounded-md ${winner === 'item2' ? 'bg-green-50 border-l-4 border-green-500' : 'bg-gray-50'}`}>
                  <span class="block text-[11px] font-bold text-muted uppercase mb-1">{item2}</span>
                  <span class={`text-[13px] ${winner === 'item2' ? 'text-green-950 font-medium' : 'text-body'}`}>{row.item2Value}</span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Detailed Pros Section -->
      <section class="mb-12 border-t border-hairline pt-8">
        <h2 class="text-title-lg font-bold text-ink mb-6">Pros & Advantages</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <!-- Item 1 Pros -->
          <div class="p-6 bg-surface-soft/30 border border-hairline rounded-lg">
            <h3 class="text-title-sm font-bold text-ink mb-4 pb-2 border-b border-hairline flex items-center gap-2">
              <span class="text-success text-lg">✓</span>
              <span>{item1} Pros</span>
            </h3>
            <ul class="flex flex-col gap-3 text-[13.5px] text-body leading-relaxed">
              {item1Pros.map(pro => (
                <li class="flex items-start gap-2.5">
                  <span class="text-success mt-0.5 shrink-0">•</span>
                  <span>{pro}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Item 2 Pros -->
          <div class="p-6 bg-surface-soft/30 border border-hairline rounded-lg">
            <h3 class="text-title-sm font-bold text-ink mb-4 pb-2 border-b border-hairline flex items-center gap-2">
              <span class="text-success text-lg">✓</span>
              <span>{item2} Pros</span>
            </h3>
            <ul class="flex flex-col gap-3 text-[13.5px] text-body leading-relaxed">
              {item2Pros.map(pro => (
                <li class="flex items-start gap-2.5">
                  <span class="text-success mt-0.5 shrink-0">•</span>
                  <span>{pro}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </section>

      <!-- Best Use Cases Section -->
      <section class="mb-12 border-t border-hairline pt-8">
        <h2 class="text-title-lg font-bold text-ink mb-6">Best Use Cases</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {useCases.map(uc => (
            <div class="p-5 border border-hairline rounded-lg bg-canvas shadow-xs">
              <h3 class="text-title-sm font-bold text-ink mb-2 line-clamp-1">{uc.situation}</h3>
              <p class="text-body-md text-muted text-[13px] leading-relaxed">{uc.recommendation}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Safety Considerations Section -->
      <section class="mb-12 border-t border-hairline pt-8">
        <h2 class="text-title-lg font-bold text-ink mb-6">Safety Considerations</h2>
        <div class="p-6 bg-[#fce8e6]/30 border border-[#fce8e6] rounded-lg">
          <ul class="flex flex-col gap-4 text-[13.5px] text-body leading-relaxed">
            {safetyNotes.map(note => (
              <li class="flex items-start gap-3">
                <span class="text-signature-coral mt-0.5 shrink-0 font-bold">⚠️</span>
                <span>{note}</span>
              </li>
            ))}
          </ul>
        </div>
      </section>

      <!-- FAQ Section -->
      <section class="mb-12 border-t border-hairline pt-8">
        <h2 class="text-title-lg font-bold text-ink mb-6">Frequently Asked Questions</h2>
        <div class="flex flex-col gap-4">
          {faqs.map(faq => (
            <details class="group border border-hairline rounded-lg bg-canvas [&_summary::-webkit-details-marker]:hidden">
              <summary class="flex justify-between items-center p-4 font-medium text-ink cursor-pointer select-none text-[14px]">
                <span>{faq.question}</span>
                <span class="text-muted group-open:rotate-180 transition-transform text-xs">▼</span>
              </summary>
              <div class="px-4 pb-4 text-body-md text-muted leading-relaxed border-t border-hairline pt-3 text-[13.5px]">
                {faq.answer}
              </div>
            </details>
          ))}
        </div>
      </section>

      <!-- Compared Individual Item Guides Grid -->
      {individualGuides.length > 0 && (
        <section class="mb-12 border-t border-hairline pt-8">
          <h2 class="text-title-lg font-bold text-ink mb-6">Compare Individual Safety Guides</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {individualGuides.map(g => (
              <a 
                href={g.url}
                class="flex items-center justify-between p-4 border border-hairline rounded-lg hover:border-border-strong hover:bg-surface-soft/40 transition-all text-decoration-none text-ink font-medium text-[13.5px] shadow-xs"
              >
                <span>{g.name.includes('Guide') ? g.name : `${g.name} Safety Guide`}</span>
                <span class="text-link text-xs">Read Guide →</span>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- Relevant Preservation & Food Storage Guides -->
      {preservationGuides.length > 0 && (
        <section class="mb-12 border-t border-hairline pt-8">
          <h2 class="text-title-lg font-bold text-ink mb-6">Shelf Life & Food Preservation Guides</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {preservationGuides.map(g => (
              <a 
                href={g.url}
                class="flex items-center justify-between p-4 border border-hairline rounded-lg hover:border-border-strong hover:bg-surface-soft/40 transition-all text-decoration-none text-ink font-medium text-[13.5px] shadow-xs"
              >
                <span>{g.name}</span>
                <span class="text-xs text-muted font-normal bg-[#e6f4ea] px-2 py-0.5 rounded-sm">{g.label}</span>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- Related Comparisons Grid -->
      {relatedComparisonObjects.length > 0 && (
        <section class="mb-12 border-t border-hairline pt-8">
          <h2 class="text-title-lg font-bold text-ink mb-6">Related Safety Comparisons</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            {relatedComparisonObjects.map(rc => (
              <a 
                href={`/compare/${rc.slug}`}
                class="block border border-hairline rounded-lg p-5 hover:border-border-strong hover:bg-surface-soft/40 transition-all text-decoration-none"
              >
                <span class="text-xs uppercase tracking-wider text-muted font-bold block mb-1">
                  {categoryNames[rc.category]}
                </span>
                <span class="text-ink font-display font-medium text-[14px] block mb-2">
                  {rc.item1} vs {rc.item2}
                </span>
                <p class="text-[12.5px] text-muted line-clamp-2 leading-relaxed">
                  {rc.verdict}
                </p>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- Back Link -->
      <footer class="border-t border-hairline pt-8 text-center">
        <a 
          href="/compare" 
          class="inline-flex items-center gap-1.5 text-link hover:underline font-medium text-[14px]"
        >
          <span>←</span>
          <span>Back to safety comparisons index</span>
        </a>
      </footer>

    </div>
  </div>
</Layout>
