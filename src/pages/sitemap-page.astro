---
import Layout from '../layouts/Layout.astro';
import itemsData from '../data/items.json';
import howLongData from '../data/how-long.json';
import washingMachineData from '../data/washing-machine.json';
import refreezeData from '../data/refreeze.json';
import whatHappensData from '../data/what-happens.json';
import blogData from '../data/blog.json';
import comparisonsData from '../data/comparisons.json';

const pageTitle = "HTML Sitemap | IsItKitchenSafe";
const pageDescription = "Explore the complete list of kitchen safety guides, appliance directions, shelf-life databases, and blog articles on the official IsItKitchenSafe sitemap.";

// Helper to format appliance names
function formatAppliance(app: string) {
  if (app === 'airfryer') return 'Air Fryer';
  return app.charAt(0).toUpperCase() + app.slice(1);
}

// Group appliance items
const appliances = ['dishwasher', 'microwave', 'freezer', 'oven', 'dryer', 'airfryer', 'refrigerator'];
const groupedApplianceItems = appliances.reduce((acc, app) => {
  acc[app] = itemsData.filter(item => item.appliance === app);
  return acc;
}, {} as Record<string, typeof itemsData>);
---

<Layout title={pageTitle} description={pageDescription}>
  <section class="max-w-[1280px] mx-auto px-6 py-12">
    <!-- Breadcrumbs -->
    <nav class="flex gap-2 text-muted text-[13px] mb-8" aria-label="Breadcrumb">
      <a href="/" class="hover:text-ink transition-colors">Home</a>
      <span>/</span>
      <span class="text-ink font-medium">Sitemap</span>
    </nav>

    <!-- Header -->
    <header class="max-w-[800px] mb-12">
      <h1 class="text-4xl md:text-5xl font-bold text-ink tracking-tight mb-4">
        HTML Sitemap
      </h1>
      <p class="text-body-md text-gray-500 text-lg leading-relaxed">
        Browse our entire collection of appliance safety guidelines, shelf-life indexes, refreeze directions, and expert kitchen safety articles.
      </p>
    </header>

    <!-- Core Pages -->
    <section class="border-t border-hairline pt-8 mb-12">
      <h2 class="text-2xl font-bold text-ink mb-6">Main Sections</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
        <div class="p-6 bg-surface-soft border border-hairline rounded-lg">
          <h3 class="text-title-sm text-ink font-bold mb-3">Core Pages</h3>
          <ul class="flex flex-col gap-2.5 text-[13px]">
            <li><a href="/" class="text-link hover:underline font-medium">Homepage</a></li>
            <li><a href="/about/" class="text-link hover:underline">About Us</a></li>
            <li><a href="/contact/" class="text-link hover:underline">Contact Support</a></li>
            <li><a href="/privacy/" class="text-link hover:underline">Privacy Policy</a></li>
          </ul>
        </div>

        <div class="p-6 bg-surface-soft border border-hairline rounded-lg">
          <h3 class="text-title-sm text-ink font-bold mb-3">Material Safety Hubs</h3>
          <ul class="flex flex-col gap-2.5 text-[13px]">
            <li><a href="/material" class="text-link hover:underline font-medium">Material Directories</a></li>
            <li><a href="/material/metal" class="text-link hover:underline">Metal Cookware & Utensils</a></li>
            <li><a href="/material/plastic" class="text-link hover:underline">Polymers & Plastics</a></li>
            <li><a href="/material/glass-ceramic" class="text-link hover:underline">Glass & Ceramics</a></li>
            <li><a href="/material/fabric" class="text-link hover:underline">Fabrics & Textiles</a></li>
            <li><a href="/material/footwear" class="text-link hover:underline">Footwear & Shoes</a></li>
            <li><a href="/material/silicone" class="text-link hover:underline">Food-Grade Silicone</a></li>
            <li><a href="/material/wood-paper" class="text-link hover:underline">Wood & Paper Products</a></li>
            <li><a href="/material/appliance-components" class="text-link hover:underline">Appliance Components</a></li>
          </ul>
        </div>

        <div class="p-6 bg-surface-soft border border-hairline rounded-lg">
          <h3 class="text-title-sm text-ink font-bold mb-3">Kitchen Safety Blog</h3>
          <ul class="flex flex-col gap-2.5 text-[13px]">
            <li><a href="/blog" class="text-link hover:underline font-medium">Blog Index</a></li>
            {blogData.map(post => (
              <li><a href={`/blog/${post.slug}`} class="text-link hover:underline line-clamp-1">{post.title}</a></li>
            ))}
          </ul>
        </div>

        <div class="p-6 bg-surface-soft border border-hairline rounded-lg">
          <h3 class="text-title-sm text-ink font-bold mb-3">Safety Comparisons</h3>
          <ul class="flex flex-col gap-2.5 text-[13px] max-h-[300px] overflow-y-auto pr-1">
            <li><a href="/compare" class="text-link hover:underline font-medium">Comparisons Index</a></li>
            {comparisonsData.map(c => (
              <li><a href={`/compare/${c.slug}`} class="text-link hover:underline line-clamp-1">{c.item1} vs {c.item2}</a></li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- Appliance Sections -->
    <section class="border-t border-hairline pt-8 mb-12">
      <h2 class="text-2xl font-bold text-ink mb-6">Appliance Reference Guides</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
        {appliances.map(app => (
          <div class="border border-hairline rounded-lg p-5">
            <h3 class="text-title-md font-bold text-ink mb-3 pb-2 border-b border-hairline flex justify-between items-center">
              <span>{formatAppliance(app)} Guides</span>
              <a href={`/${app}`} class="text-xs text-link hover:underline">View All ({groupedApplianceItems[app].length})</a>
            </h3>
            <ul class="flex flex-col gap-2 text-[13px] max-h-[250px] overflow-y-auto pr-1">
              {groupedApplianceItems[app].map(item => (
                <li>
                  <a href={`/${app}/${item.slug}`} class="text-muted hover:text-link block truncate">
                    Can You Put {item.item} in the {formatAppliance(app)}?
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- Other Safety Directories -->
    <section class="border-t border-hairline pt-8 mb-12">
      <h2 class="text-2xl font-bold text-ink mb-6">Safety Directories</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <!-- Shelf Life -->
        <div class="border border-hairline rounded-lg p-5">
          <h3 class="text-title-md font-bold text-ink mb-3 pb-2 border-b border-hairline flex justify-between items-center">
            <span>Shelf Life Guides</span>
            <a href="/how-long" class="text-xs text-link hover:underline">View All ({howLongData.length})</a>
          </h3>
          <ul class="flex flex-col gap-2 text-[13px] max-h-[250px] overflow-y-auto pr-1">
            {howLongData.map(item => (
              <li>
                <a href={`/how-long/${item.slug}`} class="text-muted hover:text-link block truncate">
                  How Long Can You Keep {item.item}?
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Washing Machine -->
        <div class="border border-hairline rounded-lg p-5">
          <h3 class="text-title-md font-bold text-ink mb-3 pb-2 border-b border-hairline flex justify-between items-center">
            <span>Washing Machine</span>
            <a href="/washing-machine" class="text-xs text-link hover:underline">View All ({washingMachineData.length})</a>
          </h3>
          <ul class="flex flex-col gap-2 text-[13px] max-h-[250px] overflow-y-auto pr-1">
            {washingMachineData.map(item => (
              <li>
                <a href={`/washing-machine/${item.slug}`} class="text-muted hover:text-link block truncate">
                  Can You Wash {item.item}?
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Refreeze Safety -->
        <div class="border border-hairline rounded-lg p-5">
          <h3 class="text-title-md font-bold text-ink mb-3 pb-2 border-b border-hairline flex justify-between items-center">
            <span>Refreeze Safety</span>
            <a href="/refreeze" class="text-xs text-link hover:underline">View All ({refreezeData.length})</a>
          </h3>
          <ul class="flex flex-col gap-2 text-[13px] max-h-[250px] overflow-y-auto pr-1">
            {refreezeData.map(item => (
              <li>
                <a href={`/refreeze/${item.slug}`} class="text-muted hover:text-link block truncate">
                  Can You Refreeze {item.item}?
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- What Happens If -->
        <div class="border border-hairline rounded-lg p-5">
          <h3 class="text-title-md font-bold text-ink mb-3 pb-2 border-b border-hairline flex justify-between items-center">
            <span>What Happens If</span>
            <a href="/what-happens" class="text-xs text-link hover:underline">View All ({whatHappensData.length})</a>
          </h3>
          <ul class="flex flex-col gap-2 text-[13px] max-h-[250px] overflow-y-auto pr-1">
            {whatHappensData.map(item => (
              <li>
                <a href={`/what-happens/${item.slug}`} class="text-muted hover:text-link block truncate">
                  What Happens If You {item.item}?
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>
  </section>
</Layout>
