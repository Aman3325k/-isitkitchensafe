---
import Layout from '../../layouts/Layout.astro';
import { CATEGORIES, getCategoryItemsAndStats } from '../../utils/materialCategories';

const pageTitle = "Kitchen Appliance Safety by Material Type | IsItKitchenSafe";
const pageDescription = "Are your kitchen items dishwasher, microwave, oven, or freezer safe? Browse safety guides and statistics by material type: metal, plastic, silicone, glass, and more.";

// pre-compile stats for the 8 categories to show item counts
const categoriesWithStats = CATEGORIES.map(cat => {
  const stats = getCategoryItemsAndStats(cat.id);
  return {
    ...cat,
    itemCount: stats ? stats.totalItemsTested : 0
  };
});
---

<Layout title={pageTitle} description={pageDescription}>
  <!-- Breadcrumbs -->
  <div class="bg-surface-soft border-b border-hairline py-4">
    <div class="max-w-[1280px] mx-auto px-6">
      <nav class="flex gap-2 text-muted text-[13px]" aria-label="Breadcrumb">
        <a href="/" class="hover:text-ink transition-colors">Home</a>
        <span>/</span>
        <span class="text-ink font-medium">Materials</span>
      </nav>
    </div>
  </div>

  <section class="max-w-[1280px] mx-auto px-6 py-[80px] md:py-[96px]">
    <!-- Header -->
    <header class="max-w-[800px] mb-12">
      <span class="text-caption text-muted uppercase tracking-wider text-xs block mb-2">Material Directories</span>
      <h1 class="text-display-lg md:text-display-xl font-medium text-ink tracking-tight mb-4">
        Kitchen Appliance Safety by Material Type
      </h1>
      <p class="text-body-md text-muted text-lg leading-relaxed">
        Select a material category below to access dynamic safety statistics, common appliance risks, and complete safety reference tables for all kitchen items.
      </p>
    </header>

    <!-- Categories Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {categoriesWithStats.map(cat => {
        const isDark = cat.styling.includes('text-white');
        return (
          <a 
            href={`/material/${cat.id}`} 
            class={`${cat.styling} border rounded-lg p-8 flex flex-col justify-between min-h-[220px] shadow-sm transition-transform active:scale-[0.98]`}
          >
            <div>
              <span class={`text-[11px] uppercase tracking-wider font-bold block mb-2 ${isDark ? 'text-white/75' : 'text-muted'}`}>
                {cat.itemCount} Items Checked
              </span>
              <h2 class={`text-title-lg font-medium tracking-tight mb-3 ${isDark ? 'text-white' : 'text-ink'}`}>
                {cat.displayName}
              </h2>
              <p class={`text-[13px] leading-relaxed mb-6 ${isDark ? 'text-white/85' : 'text-body'}`}>
                {cat.description}
              </p>
            </div>
            <span class={`text-[13px] font-medium underline underline-offset-4 flex items-center gap-1 ${isDark ? 'text-white' : 'text-link'}`}>
              Explore guides &rarr;
            </span>
          </a>
        );
      })}
    </div>
  </section>
</Layout>
