---
import Layout from '../../layouts/Layout.astro';
import whatHappensData from '../../data/what-happens.json';

const pageTitle = "What Happens If You Put X in Y? Accident Guides | IsItKitchenSafe";
const pageDescription = "Explore the physical and safety consequences of common kitchen actions. Learn what happens if you microwave foil, freeze soda, or mix cleaning agents.";

const indexFaqs = [
  {
    question: "Why is mixing bleach and ammonia dangerous?",
    answer: "Mixing bleach and ammonia releases toxic chloramine gas, which causes immediate respiratory damage, irritation, and can be lethal in enclosed spaces."
  },
  {
    question: "What happens if a microwave runs empty?",
    answer: "Without food or moisture to absorb the electromagnetic waves, the waves bounce back to the magnetron tube, causing it to overheat and fail, potentially starting a fire."
  }
];
---

<Layout title={pageTitle} description={pageDescription} faqs={indexFaqs}>
  <!-- Hero Section -->
  <section class="bg-[#181d26] text-on-dark py-[64px] md:py-[80px]">
    <div class="max-w-[1280px] mx-auto px-6">
      <nav class="flex gap-2 text-[13px] text-muted mb-6" aria-label="Breadcrumb">
        <a href="/" class="hover:underline">Home</a>
        <span>/</span>
        <span class="font-medium text-white">What Happens If</span>
      </nav>
      
      <h1 class="text-display-lg font-medium tracking-tight mb-4 text-white">
        What Happens If... Guides
      </h1>
      <p class="text-white/80 text-body-md max-w-2xl leading-relaxed">
        Search and explore the chemical, physical, and hazard results of everyday kitchen accidents. Learn how to prevent kitchen fires, material damage, and health hazards.
      </p>
    </div>
  </section>

  <!-- Items Grid Section -->
  <section class="max-w-[1280px] mx-auto px-6 py-[96px]">
    <div class="flex flex-col md:flex-row md:items-end justify-between border-b border-hairline pb-8 mb-12">
      <div>
        <h2 class="text-display-md text-ink tracking-tight mb-2">Tested Scenarios ({whatHappensData.length})</h2>
        <p class="text-body-md text-muted">A comprehensive safety analysis of daily kitchen habits and potential accidents.</p>
      </div>
      
      <!-- Filter Input -->
      <div class="mt-6 md:mt-0 flex gap-3 max-w-[320px] w-full">
        <input 
          type="text" 
          id="filter-input"
          placeholder="Search scenarios (e.g. foil)..."
          class="w-full h-10 px-3 py-2 bg-canvas text-ink text-[14px] border border-hairline rounded-sm focus:outline-none focus:border-info-border"
        />
      </div>
    </div>

    <!-- Items Grid -->
    <div id="items-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {whatHappensData.map(item => (
        <div 
          class="item-card bg-canvas border border-hairline rounded-md p-6 flex flex-col justify-between shadow-xs transition-all hover:border-border-strong"
          data-name={item.item.toLowerCase()}
        >
          <div>
            <div class="flex items-center justify-between mb-4">
              <span class="text-caption text-muted uppercase tracking-wider text-xs">{item.type}</span>
              {item.dangerLevel === 'dangerous' && <span class="badge-no">DANGEROUS</span>}
              {item.dangerLevel === 'caution' && <span class="badge-depends">CAUTION</span>}
              {item.dangerLevel === 'safe' && <span class="badge-yes">SAFE</span>}
            </div>
            
            <h3 class="text-title-sm text-ink mb-3">
              What Happens If You {item.item.replace(/-/g, ' ')}?
            </h3>
            
            <p class="text-body-md text-body leading-relaxed mb-6">
              {item.shortAnswer}
            </p>
          </div>
          
          <a 
            href={`/what-happens/${item.slug}`} 
            class="text-link text-[14px] font-medium hover:text-link-active transition-colors flex items-center gap-1 group mt-4"
          >
            Read what happens &rarr;
          </a>
        </div>
      ))}
    </div>

    <!-- No results message -->
    <div id="no-results" class="hidden text-center py-12">
      <p class="text-title-md text-muted">No scenarios match your search.</p>
    </div>
  </section>

  <!-- Client-side filtering script -->
  <script is:inline>
    const filterInput = document.getElementById('filter-input');
    const itemsGrid = document.getElementById('items-grid');
    const noResults = document.getElementById('no-results');

    if (filterInput && itemsGrid) {
      const cards = itemsGrid.getElementsByClassName('item-card');
      
      filterInput.addEventListener('input', (e) => {
        const query = e.target.value.trim().toLowerCase();
        let matches = 0;
        
        for (let i = 0; i < cards.length; i++) {
          const card = cards[i];
          const name = card.getAttribute('data-name');
          
          if (name.includes(query)) {
            card.style.display = '';
            matches++;
          } else {
            card.style.display = 'none';
          }
        }
        
        if (matches === 0) {
          noResults.classList.remove('hidden');
        } else {
          noResults.classList.add('hidden');
        }
      });
    }
  </script>
</Layout>
