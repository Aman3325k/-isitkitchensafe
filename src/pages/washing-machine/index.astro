---
import Layout from '../../layouts/Layout.astro';
import washingMachineData from '../../data/washing-machine.json';

const pageTitle = "Washing Machine Durability & Safety Guides | IsItKitchenSafe";
const pageDescription = "Explore our guidelines for washing fabrics, household items, garments, and shoes. Learn what can safely go in the washing machine without causing damage.";
---

<Layout title={pageTitle} description={pageDescription}>
  <!-- Hero Section -->
  <section class="bg-signature-coral text-on-primary py-[64px] md:py-[80px]">
    <div class="max-w-[1280px] mx-auto px-6">
      <nav class="flex gap-2 text-[13px] opacity-75 mb-6" aria-label="Breadcrumb">
        <a href="/" class="hover:underline">Home</a>
        <span>/</span>
        <span class="font-medium">Washing Machine</span>
      </nav>
      
      <h1 class="text-display-lg font-medium tracking-tight mb-4">
        Washing Machine Safety Guides
      </h1>
      <p class="text-white/80 text-body-md max-w-2xl leading-relaxed">
        Check safety instructions and settings for daily garments, shoes, and home textiles. Keep your washer and fabrics in perfect shape.
      </p>
    </div>
  </section>

  <!-- Items Grid Section -->
  <section class="max-w-[1280px] mx-auto px-6 py-[96px]">
    <div class="flex flex-col md:flex-row md:items-end justify-between border-b border-hairline pb-8 mb-12">
      <div>
        <h2 class="text-display-md text-ink tracking-tight mb-2">Tested Items ({washingMachineData.length})</h2>
        <p class="text-body-md text-muted">Complete listings of items evaluated for washing machine durability.</p>
      </div>
      
      <!-- Filter Input -->
      <div class="mt-6 md:mt-0 flex gap-3 max-w-[320px] w-full">
        <input 
          type="text" 
          id="filter-input"
          placeholder="Search items (e.g. sneakers)..."
          aria-label="Search items"
          class="w-full h-10 px-3 py-2 bg-canvas text-ink text-[14px] border border-hairline rounded-sm focus:outline-none focus:border-info-border"
        />
      </div>
    </div>

    <!-- Items Grid -->
    <div id="items-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {washingMachineData.map(item => (
        <div 
          class="item-card bg-canvas border border-hairline rounded-md p-6 flex flex-col justify-between shadow-xs transition-all hover:border-border-strong"
          data-name={item.item.toLowerCase()}
        >
          <div>
            <div class="flex items-center justify-between mb-4">
              <span class="text-caption text-muted uppercase tracking-wider text-xs">Washing Machine</span>
              {item.safe === 'yes' && <span class="badge-yes">YES</span>}
              {item.safe === 'no' && <span class="badge-no">NO</span>}
              {item.safe === 'depends' && <span class="badge-depends">DEPENDS</span>}
            </div>
            
            <h3 class="text-title-sm text-ink mb-3">
              Can You Put {item.item} in the Washing Machine?
            </h3>
            
            <p class="text-body-md text-body leading-relaxed mb-6">
              {item.shortAnswer}
            </p>
          </div>
          
          <a 
            href={`/washing-machine/${item.slug}`} 
            class="text-link text-[14px] font-medium hover:text-link-active transition-colors flex items-center gap-1 group mt-4"
          >
            Read washing details <span class="group-hover:translate-x-0.5 transition-transform">&rarr;</span>
          </a>
        </div>
      ))}
    </div>

    <!-- No results message -->
    <div id="no-results" class="hidden text-center py-12">
      <p class="text-title-md text-muted">No items match your search.</p>
    </div>
  </section>

  <!-- Client-side filtering script -->
  <script is:inline>
    const filterInput = document.getElementById('filter-input');
    const itemsGrid = document.getElementById('items-grid');
    const noResults = document.getElementById('no-results');

    if (filterInput && itemsGrid) {
      const cards = itemsGrid.getElementsByClassName('item-card');
      
      filterInput.addEventListener('input', (e) => {
        const query = e.target.value.trim().toLowerCase();
        let matches = 0;
        
        for (let i = 0; i < cards.length; i++) {
          const card = cards[i];
          const name = card.getAttribute('data-name');
          
          if (name.includes(query)) {
            card.classList.remove('hidden');
            matches++;
          } else {
            card.classList.add('hidden');
          }
        }
        
        if (matches === 0) {
          noResults.classList.remove('hidden');
        } else {
          noResults.classList.add('hidden');
        }
      });
    }
  </script>
</Layout>
