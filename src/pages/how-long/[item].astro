---
import Layout from '../../layouts/Layout.astro';
import howLongData from '../../data/how-long.json';
import { generateHowLongMetaDescription, getUniqueSafetyAnalysis } from '../../utils/seoHelper.js';
import { resolveAllGuidesForItem, getPeopleAlsoAsk, getRelatedCategoriesForItem } from '../../utils/linkingHelper.js';

export function getStaticPaths() {
  return howLongData.map((item) => {
    return {
      params: {
        item: item.slug
      },
      props: {
        data: item
      }
    };
  });
}

interface Props {
  data: typeof howLongData[number];
}

const { data } = Astro.props;

// Format location name
function formatLocation(loc: string) {
  if (loc === 'fridge') return 'Refrigerator';
  if (loc === 'counter') return 'Countertop';
  return loc.charAt(0).toUpperCase() + loc.slice(1);
}

const formattedLocation = formatLocation(data.location);
const formattedAnswer = data.safe.toUpperCase(); // "YES", "NO", "DEPENDS"

const pageTitle = `How Long Can You Keep ${data.item} in the ${formattedLocation}? | IsItKitchenSafe`;
const pageDescription = generateHowLongMetaDescription(data.item, formattedLocation, data.duration, data.shortAnswer);

// Get related items
let relatedItems = howLongData.filter(item => data.relatedItems.includes(item.slug) && item.slug !== data.slug);
if (relatedItems.length < 5) {
  const sameLocationItems = howLongData.filter(item => item.location === data.location && item.slug !== data.slug && !data.relatedItems.includes(item.slug));
  const existingSlugs = new Set(relatedItems.map(i => i.slug));
  for (const item of sameLocationItems) {
    if (relatedItems.length >= 5) break;
    if (!existingSlugs.has(item.slug)) {
      relatedItems.push(item);
      existingSlugs.add(item.slug);
    }
  }
}
if (relatedItems.length < 5) {
  const anyItems = howLongData.filter(item => item.slug !== data.slug && !relatedItems.some(ri => ri.slug === item.slug));
  for (const item of anyItems) {
    if (relatedItems.length >= 5) break;
    relatedItems.push(item);
  }
}
relatedItems = relatedItems.slice(0, 5);

const allGuides = resolveAllGuidesForItem(data.item, data.slug);
const currentPath = `/how-long/${data.slug}`;
const paaList = getPeopleAlsoAsk(data.item, data.slug, allGuides, data.relatedItems);
const relatedCategories = getRelatedCategoriesForItem(data.item, data.slug, currentPath, allGuides);

// Dynamic unique safety analysis
const uniqueAnalysis = getUniqueSafetyAnalysis(data.item, formattedLocation, data.safe, data.shortAnswer, data.storageTips, data.spoilageSigns);

const speakableSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "speakable": {
    "@type": "SpeakableSpecification",
    "cssSelector": [".quick-answer", ".short-answer", "h1"]
  }
};

const howToSchema = (data.safe === 'yes' || data.safe === 'depends') ? {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": `How to safely store ${data.item} in the ${formattedLocation}`,
  "description": data.shortAnswer,
  "step": data.storageTips.map((tip, idx) => ({
    "@type": "HowToStep",
    "position": idx + 1,
    "text": tip
  }))
} : null;
---

<Layout title={pageTitle} description={pageDescription} faqs={data.faqs}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(speakableSchema)} />
    {howToSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
    )}
  </Fragment>
  <article class="max-w-[800px] mx-auto px-6 py-[48px] md:py-[64px]">
    <!-- Breadcrumbs -->
    <nav class="flex gap-2 text-muted text-[13px] mb-8" aria-label="Breadcrumb">
      <a href="/" class="hover:text-ink transition-colors">Home</a>
      <span>/</span>
      <a href="/how-long" class="hover:text-ink transition-colors">How Long</a>
      <span>/</span>
      <span class="text-ink font-medium">{data.item}</span>
    </nav>

    <!-- Header Section -->
    <header class="mb-10 text-center md:text-left">
      <div class="flex flex-wrap items-center justify-center md:justify-start gap-3 mb-3">
        <span class="text-caption text-muted uppercase tracking-wider text-xs">{formattedLocation} Guide</span>
        <span class="text-xs text-muted border-l border-hairline pl-3">Last Updated: June 2026</span>
        <span class="text-xs text-success font-medium bg-[#e6f4ea] px-2 py-0.5 rounded-sm">✓ Based on USDA/FDA guidelines</span>
      </div>
      
      <h1 class="text-display-md md:text-display-lg font-medium text-ink tracking-tight mb-6 leading-tight">
        Can You Put {data.item} in the {formattedLocation}?
      </h1>

      <!-- Safety Verdict Badge & Duration Badge -->
      <div class="flex flex-wrap items-center justify-center md:justify-start gap-3">
        {data.safe === 'yes' && (
          <div class="badge-yes quick-answer px-6 py-2 text-sm">
            <span class="mr-1.5">✓</span> YES
          </div>
        )}
        {data.safe === 'no' && (
          <div class="badge-no quick-answer px-6 py-2 text-sm">
            <span class="mr-1.5">✗</span> NO
          </div>
        )}
        {data.safe === 'depends' && (
          <div class="badge-depends quick-answer px-6 py-2 text-sm">
            <span class="mr-1.5">⚠</span> DEPENDS
          </div>
        )}
        
        <div class="badge-time px-6 py-2 text-sm">
          <span class="mr-1.5">⏱</span> LASTS: {data.duration}
        </div>
      </div>
    </header>

    <!-- Quick Summary (Shareable Box) -->
    <section class="mb-12">
      <div class="bg-signature-cream/40 border border-signature-cream rounded-md p-6">
        <h2 class="text-title-sm text-ink font-medium mb-4 flex items-center gap-2">
          📋 Storage Quick Summary
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 text-[14px]">
          <div>
            <span class="text-muted block mb-1">Item to Store:</span>
            <strong class="text-ink text-[16px]">{data.item}</strong>
          </div>
          <div>
            <span class="text-muted block mb-1">Recommended Location:</span>
            <strong class="text-ink text-[16px]">{formattedLocation}</strong>
          </div>
          <div>
            <span class="text-muted block mb-1">Safe Shelf Life:</span>
            <strong class="text-link text-[16px]">{data.duration}</strong>
          </div>
          <div>
            <span class="text-muted block mb-1">Main Rule:</span>
            <strong class="text-success text-[16px]">Airtight Container</strong>
          </div>
        </div>
      </div>
    </section>

    <!-- Detailed Explanation -->
    <section class="mb-12">
      <div class="p-8 rounded-lg bg-[#f8fafc] border border-hairline">
        <h2 class="text-title-sm text-ink font-medium mb-3">Can You Keep {data.item} in the {formattedLocation}?</h2>
        <p class="short-answer text-title-md font-bold leading-relaxed text-ink mb-4">
          {data.shortAnswer}
        </p>
        <div class="border-t border-hairline my-4 opacity-50"></div>
        <h3 class="text-caption text-muted mb-2 font-semibold uppercase tracking-wider text-xs">Full Details & Science</h3>
        {data.reason.split('\n\n').map(para => (
          <p class="text-body-md text-body leading-relaxed mb-4">
            {para}
          </p>
        ))}
        {uniqueAnalysis.map(para => (
          <p class="text-body-md text-body leading-relaxed mb-4 last:mb-0">
            {para}
          </p>
        ))}
      </div>
    </section>

    <!-- Did you know / Fun fact -->
    <section class="mb-12">
      <div class="bg-surface-soft border border-hairline rounded-md p-6">
        <h3 class="text-title-sm text-ink font-medium mb-2">💡 Did You Know?</h3>
        <p class="text-body-md text-body leading-relaxed">
          Pathogenic bacteria can grow rapidly in the "Danger Zone" between 40°F and 140°F. Storing {data.item} properly in the {formattedLocation} slows this growth down dramatically, keeping your food safe for longer!
        </p>
      </div>
    </section>

    <!-- Storage Tips and Spoilage Signs -->
    <section class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
      <!-- Tips -->
      <div class="bg-surface-soft rounded-md p-6 border border-hairline/50">
        <h2 class="text-title-sm text-ink font-medium mb-4 flex items-center gap-2">
          ✅ Best Storage Tips
        </h2>
        <ul class="flex flex-col gap-3">
          {data.storageTips.map(tip => (
            <li class="text-body-md text-body flex gap-2.5 items-start leading-relaxed">
              <span class="text-success font-bold mt-0.5">✓</span>
              <span>{tip}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Spoilage -->
      <div class="bg-surface-soft rounded-md p-6 border border-hairline/50">
        <h2 class="text-title-sm text-ink font-medium mb-4 flex items-center gap-2">
          🔍 Signs of Spoilage
        </h2>
        <ul class="flex flex-col gap-3">
          {data.spoilageSigns.map(sign => (
            <li class="text-body-md text-body flex gap-2.5 items-start leading-relaxed">
              <span class="text-signature-coral font-bold mt-0.5">⚠</span>
              <span>{sign}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="border-t border-hairline pt-12 mb-16">
      <h2 class="text-title-lg text-ink font-medium tracking-tight mb-8">Frequently Asked Questions</h2>
      <div class="flex flex-col">
        {data.faqs.map(faq => (
          <details class="group border-b border-hairline py-5">
            <summary class="flex items-center justify-between text-title-sm text-ink font-medium cursor-pointer list-none [&::-webkit-details-marker]:hidden select-none">
              <span>{faq.question}</span>
              <span class="text-muted group-open:rotate-180 transition-transform duration-200">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </span>
            </summary>
            <div class="mt-4 text-body-md text-body leading-relaxed pl-1">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    <!-- Direct Cross-linking Guides Box -->
    {(allGuides.applianceGuides.length > 0 || allGuides.refreezeGuides.length > 0 || allGuides.whatHappensGuides.length > 0 || allGuides.comparisonGuides.length > 0) && (
      <section class="mb-12 border-t border-hairline pt-12">
        <h2 class="text-title-lg text-ink font-medium tracking-tight mb-6">Cross-Reference Safety Guides for {data.item}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {allGuides.applianceGuides.map(g => (
            <a href={g.url} class="p-4 bg-canvas border border-hairline rounded-md hover:border-border-strong text-body-md text-link flex justify-between items-center transition-colors shadow-xs">
              <span class="font-medium">🔌 Appliance: {g.appliance.toUpperCase()}</span>
              <span class="text-xs text-muted">Read guide &rarr;</span>
            </a>
          ))}
          {allGuides.refreezeGuides.map(g => (
            <a href={g.url} class="p-4 bg-canvas border border-hairline rounded-md hover:border-border-strong text-body-md text-link flex justify-between items-center transition-colors shadow-xs">
              <span class="font-medium">❄️ Refreezing Safety Rules</span>
              <span class="text-xs text-muted">Read guide &rarr;</span>
            </a>
          ))}
          {allGuides.whatHappensGuides.map(g => (
            <a href={g.url} class="p-4 bg-canvas border border-hairline rounded-md hover:border-border-strong text-body-md text-link flex justify-between items-center transition-colors shadow-xs">
              <span class="font-medium">⚠️ Accident Hazards & Danger</span>
              <span class="text-xs text-muted">Read guide &rarr;</span>
            </a>
          ))}
          {allGuides.comparisonGuides.map(g => (
            <a href={g.url} class="p-4 bg-canvas border border-hairline rounded-md hover:border-border-strong text-body-md text-link flex justify-between items-center transition-colors shadow-xs">
              <span class="font-medium">⚔️ Comparison: {g.item1} vs {g.item2}</span>
              <span class="text-xs text-muted">Compare &rarr;</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- People Also Ask Section -->
    <section class="border-t border-hairline pt-12 mb-16">
      <h2 class="text-title-lg text-ink font-medium tracking-tight mb-8">People Also Ask</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {paaList.map(paa => (
          <a 
            href={paa.url} 
            class="bg-canvas border border-hairline hover:border-border-strong rounded-md p-5 flex flex-col justify-between shadow-xs transition-colors active:scale-[0.98]"
          >
            <div>
              <span class="text-[11px] text-muted uppercase tracking-wider block mb-2">Related Question</span>
              <h3 class="text-title-sm text-ink mb-2 leading-snug">
                {paa.question}
              </h3>
            </div>
            <span class="text-[12px] font-medium text-link mt-4 block">View Answer &rarr;</span>
          </a>
        ))}
      </div>
    </section>

    <!-- Related Items -->
    <section class="border-t border-hairline pt-12 mb-16">
      <h2 class="text-title-lg text-ink font-medium tracking-tight mb-8">Related Storage Guides</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {relatedItems.map(item => (
          <a 
            href={`/how-long/${item.slug}`} 
            class="bg-canvas border border-hairline hover:border-border-strong rounded-md p-5 flex flex-col justify-between shadow-xs transition-colors active:scale-[0.98]"
          >
            <div>
              <div class="flex items-center justify-between mb-3">
                <span class="text-[11px] text-muted uppercase tracking-wider">{formatLocation(item.location)}</span>
                <span class="badge-time text-[10px] px-2 py-0.5">{item.duration}</span>
              </div>
              <h3 class="text-title-sm text-ink mb-1">
                {item.item}
              </h3>
              <p class="text-[13px] text-muted line-clamp-2 leading-relaxed">
                {item.shortAnswer}
              </p>
            </div>
            <span class="text-[12px] font-medium text-link mt-4 block">Read guide &rarr;</span>
          </a>
        ))}
      </div>
    </section>

    <!-- Related Categories Section -->
    {relatedCategories.length > 0 && (
      <section class="border-t border-hairline pt-12 mb-12">
        <h2 class="text-title-lg text-ink font-medium tracking-tight mb-6 font-display">Explore Related Safety Categories</h2>
        <div class="flex flex-wrap gap-3">
          {relatedCategories.map(cat => (
            <a 
              href={cat.url}
              class="px-4 py-2 bg-surface-soft border border-hairline rounded-full text-[13px] font-medium text-ink hover:border-border-strong transition-colors"
            >
              {cat.name} &rarr;
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Back Link -->
    <div class="mt-12 pt-8 border-t border-hairline text-center">
      <a 
        href="/how-long" 
        class="text-link text-[14px] font-medium hover:text-link-active transition-colors inline-flex items-center gap-1.5 active:scale-[0.98] transition-transform"
      >
        &larr; Back to all Shelf Life Guides
      </a>
    </div>
  </article>
</Layout>
