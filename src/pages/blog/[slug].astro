---
import Layout from '../../layouts/Layout.astro';
import blogData from '../../data/blog.json';

export function getStaticPaths() {
  return blogData.map((article) => {
    return {
      params: {
        slug: article.slug
      },
      props: {
        article
      }
    };
  });
}

interface Props {
  article: typeof blogData[number];
}

const { article } = Astro.props;

// SEO title and description
const pageTitle = `${article.title} | IsItKitchenSafe`;
const pageDescription = article.excerpt;
---

<Layout title={pageTitle} description={pageDescription} faqs={article.faqs}>
  <article class="max-w-[1280px] mx-auto px-6 py-12">
    <!-- Breadcrumbs -->
    <nav class="flex gap-2 text-muted text-[13px] mb-8" aria-label="Breadcrumb">
      <a href="/" class="hover:text-ink transition-colors">Home</a>
      <span>/</span>
      <a href="/blog" class="hover:text-ink transition-colors">Blog</a>
      <span>/</span>
      <span class="text-ink font-medium line-clamp-1">{article.title}</span>
    </nav>

    <!-- Header Section -->
    <header class="max-w-[800px] mb-10">
      <span class="text-xs uppercase tracking-wider text-link font-bold block mb-2">Kitchen Safety Guide</span>
      <h1 class="text-3xl md:text-5xl font-bold text-ink tracking-tight mb-6 leading-tight">
        {article.title}
      </h1>
      
      <!-- Trust Signals and Metadata -->
      <div class="flex flex-wrap items-center gap-4 text-xs text-muted border-b border-hairline pb-6">
        <span>By <strong>{article.author}</strong></span>
        <span class="hidden sm:inline">•</span>
        <span>Published: <strong>{article.date}</strong></span>
        <span class="hidden sm:inline">•</span>
        <span>Read time: <strong>{article.readTime}</strong></span>
        <span class="hidden sm:inline">•</span>
        <span class="inline-flex items-center gap-1 text-success font-medium bg-[#e6f4ea] px-2.5 py-0.5 rounded-full">
          ✓ Science-Backed (USDA/FDA)
        </span>
      </div>
    </header>

    <!-- AdSense Top Banner -->
    <div class="ad-placeholder w-full h-[90px] bg-[#f8fafc] border border-dashed border-hairline flex items-center justify-center text-xs text-muted mb-10" aria-hidden="true">
      <!-- Empty placeholder for AdSense banner -->
    </div>

    <!-- Main Grid Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-10">
      <!-- Left side: Main Article Content -->
      <div class="lg:col-span-3 flex flex-col gap-8">
        <!-- Intro Paragraph -->
        <p class="text-[16px] md:text-[18px] text-body leading-relaxed font-normal">
          {article.intro}
        </p>

        <!-- Sections -->
        {article.sections.map((section) => (
          <section class="border-t border-hairline pt-8">
            <h2 class="text-2xl font-bold text-ink mb-4">{section.title}</h2>
            <p class="text-body-md text-body leading-relaxed mb-6">
              {section.content}
            </p>

            <!-- Callout Box depending on type -->
            {section.boxText && (
              <div class={`p-5 rounded-md border text-[13.5px] leading-relaxed ${
                section.type === 'warning' ? 'bg-signature-cream/50 border-signature-cream text-ink' :
                section.type === 'success' || section.type === 'fact' ? 'bg-[#f4faf6] border-[#39bf45]/20 text-ink' :
                'bg-surface-soft border-hairline text-ink'
              }`}>
                <div class="flex gap-2.5 items-start">
                  <span class="text-base leading-none">
                    {section.type === 'warning' ? '⚠️' :
                     section.type === 'success' || section.type === 'fact' ? '💡' : 'ℹ️'}
                  </span>
                  <div>
                    <strong class="block text-ink font-semibold mb-0.5">
                      {section.type === 'warning' ? 'Critical Warning' :
                       section.type === 'success' || section.type === 'fact' ? 'Science Fact' : 'Safety Tip'}
                    </strong>
                    {section.boxText}
                  </div>
                </div>
              </div>
            )}
          </section>
        ))}

        <!-- Conclusion -->
        <section class="border-t border-hairline pt-8 bg-surface-soft/40 p-6 rounded-lg">
          <h2 class="text-2xl font-bold text-ink mb-4">Conclusion</h2>
          <p class="text-body-md text-body leading-relaxed">
            {article.conclusion}
          </p>
        </section>

        <!-- FAQ Section -->
        <section class="border-t border-hairline pt-10">
          <h2 class="text-2xl md:text-3xl font-bold text-ink mb-6">Frequently Asked Questions</h2>
          <div class="flex flex-col">
            {article.faqs.map((faq) => (
              <details class="group border-b border-hairline py-4">
                <summary class="flex items-center justify-between text-title-sm text-ink font-medium cursor-pointer list-none [&::-webkit-details-marker]:hidden select-none">
                  <span>{faq.question}</span>
                  <span class="text-muted group-open:rotate-180 transition-transform duration-200">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                    </svg>
                  </span>
                </summary>
                <div class="mt-3 text-body-md text-body leading-relaxed pl-1">
                  {faq.answer}
                </div>
              </details>
            ))}
          </div>
        </section>

        <!-- Back to Blog Navigation -->
        <div class="mt-8 pt-8 border-t border-hairline flex justify-between items-center">
          <a href="/blog" class="text-link text-[14px] font-medium hover:text-link-active transition-colors">
            &larr; Back to Safety Blog
          </a>
          <a href="/" class="text-link text-[14px] font-medium hover:text-link-active transition-colors">
            Search Appliance Guides &rarr;
          </a>
        </div>
      </div>

      <!-- Right side: Sidebar -->
      <aside class="flex flex-col gap-8">
        <!-- Sidebar AdSense Placeholder -->
        <div class="ad-placeholder w-full h-[250px] bg-[#f8fafc] border border-dashed border-hairline flex items-center justify-center text-xs text-muted" aria-hidden="true">
          <!-- Empty placeholder for AdSense rectangle -->
        </div>

        <!-- Related Guides / Tools Link Box -->
        <div class="border border-hairline rounded-lg p-6 bg-canvas shadow-xs">
          <h3 class="text-title-sm text-ink font-bold mb-4">Related Safety Guides</h3>
          <ul class="flex flex-col gap-3">
            {article.relatedTools.map((tool) => (
              <li>
                <a 
                  href={tool.url} 
                  class="text-[13px] text-link hover:underline font-medium leading-normal block"
                >
                  {tool.name} &rarr;
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Safety Pledge Trust Signals -->
        <div class="border border-hairline rounded-lg p-6 bg-[#fcfbfa]">
          <h4 class="text-xs uppercase tracking-wider text-muted font-bold mb-2">Our Safety Policy</h4>
          <p class="text-xs text-gray-500 leading-relaxed mb-3">
            Every guide is thoroughly researched using recommendations from the Food Safety and Inspection Service (FSIS), USDA, and FDA.
          </p>
          <span class="text-[10px] text-muted block">Last updated: June 2026</span>
        </div>

        <!-- Sidebar AdSense Bottom Placeholder -->
        <div class="ad-placeholder w-full h-[600px] bg-[#f8fafc] border border-dashed border-hairline flex items-center justify-center text-xs text-muted" aria-hidden="true">
          <!-- Empty placeholder for AdSense skyscraper -->
        </div>
      </aside>
    </div>
  </article>
</Layout>
