---
import Layout from '../../layouts/Layout.astro';
import blogData from '../../data/blog.json';
import itemsData from '../../data/items.json';
import comparisonsData from '../../data/comparisons.json';
import { injectInlineLinks } from '../../utils/linkingHelper.js';

export function getStaticPaths() {
  return blogData.map((article) => {
    return {
      params: {
        slug: article.slug
      },
      props: {
        article
      }
    };
  });
}

interface Props {
  article: typeof blogData[number];
}

const { article } = Astro.props;

// 1. Process inline linking (minimum 10 relevant item links)
const linksInjected = new Set();
const linkCountRef = { count: 0 };

const itemsToMatch = itemsData.map(i => ({
  name: i.item,
  slug: i.slug,
  appliance: i.appliance,
  url: `/${i.appliance}/${i.slug}`
})).sort((a, b) => b.name.length - a.name.length);

const linkedIntro = injectInlineLinks(article.intro, itemsToMatch, linksInjected, linkCountRef);
const linkedSections = article.sections.map(sec => {
  const linkedContent = injectInlineLinks(sec.content, itemsToMatch, linksInjected, linkCountRef);
  let linkedBoxText = sec.boxText;
  if (linkedBoxText) {
    linkedBoxText = injectInlineLinks(linkedBoxText, itemsToMatch, linksInjected, linkCountRef);
  }
  return {
    ...sec,
    content: linkedContent,
    boxText: linkedBoxText
  };
});
const linkedConclusion = injectInlineLinks(article.conclusion, itemsToMatch, linksInjected, linkCountRef);

// Fallback resources if inline matches are under 10
const fallbackGuides = [];
if (linkCountRef.count < 10) {
  const needed = 10 - linkCountRef.count;
  for (const item of itemsToMatch) {
    if (fallbackGuides.length >= needed) break;
    if (!linksInjected.has(item.url)) {
      fallbackGuides.push(item);
      linksInjected.add(item.url);
      linkCountRef.count++;
    }
  }
}

// 2. Select 3 related blog articles
const relatedArticles = blogData.filter(a => a.slug !== article.slug).slice(0, 3);

// 3. Select relevant comparisons
const relevantComparisons = comparisonsData.filter(c => 
  article.title.toLowerCase().includes(c.item1.toLowerCase()) || 
  article.title.toLowerCase().includes(c.item2.toLowerCase()) ||
  article.intro.toLowerCase().includes(c.item1.toLowerCase()) ||
  article.intro.toLowerCase().includes(c.item2.toLowerCase())
).slice(0, 3);

// SEO title and description
const pageTitle = `${article.title} | IsItKitchenSafe`;
const pageDescription = article.excerpt;

// Calculate realistic word count estimate
const fullText = [
  article.intro,
  ...article.sections.map(s => s.content + ' ' + (s.boxText || '')),
  article.conclusion
].join(' ');
const estimatedWordCount = fullText.split(/\s+/).filter(Boolean).length;

const canonicalUrl = `https://isitkitchensafe.com/blog/${article.slug}`;

const blogPostingSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": article.title,
  "description": article.excerpt,
  "author": {
    "@type": "Organization",
    "name": "IsItKitchenSafe Editorial Team"
  },
  "publisher": {
    "@type": "Organization",
    "name": "IsItKitchenSafe",
    "logo": {
      "@type": "ImageObject",
      "url": "https://isitkitchensafe.com/og-image.png"
    }
  },
  "datePublished": article.date,
  "dateModified": "2026-06-13",
  "image": "https://isitkitchensafe.com/og-image.png",
  "wordCount": estimatedWordCount,
  "articleSection": "Kitchen Safety",
  "url": canonicalUrl
};
---

<Layout title={pageTitle} description={pageDescription} faqs={article.faqs} excludeArticleSchema={true}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(blogPostingSchema)} />
  <article class="max-w-[1280px] mx-auto px-6 py-12">
    <!-- Breadcrumbs -->
    <nav class="flex gap-2 text-muted text-[13px] mb-8" aria-label="Breadcrumb">
      <a href="/" class="hover:text-ink transition-colors">Home</a>
      <span>/</span>
      <a href="/blog" class="hover:text-ink transition-colors">Blog</a>
      <span>/</span>
      <span class="text-ink font-medium line-clamp-1">{article.title}</span>
    </nav>

    <!-- Header Section -->
    <header class="max-w-[800px] mb-10">
      <span class="text-xs uppercase tracking-wider text-link font-bold block mb-2">Kitchen Safety Guide</span>
      <h1 class="text-3xl md:text-5xl font-bold text-ink tracking-tight mb-6 leading-tight">
        {article.title}
      </h1>
      
      <!-- Trust Signals and Metadata -->
      <div class="flex flex-wrap items-center gap-4 text-xs text-muted border-b border-hairline pb-6">
        <span>By <strong>{article.author}</strong></span>
        <span class="hidden sm:inline">•</span>
        <span>Published: <strong>{article.date}</strong></span>
        <span class="hidden sm:inline">•</span>
        <span>Read time: <strong>{article.readTime}</strong></span>
        <span class="hidden sm:inline">•</span>
        <span class="inline-flex items-center gap-1 text-success font-medium bg-[#e6f4ea] px-2.5 py-0.5 rounded-full">
          ✓ Science-Backed (USDA/FDA)
        </span>
      </div>
    </header>

    <!-- AdSense Top Banner -->
    <div class="ad-placeholder w-full h-[90px] bg-[#f8fafc] border border-dashed border-hairline flex items-center justify-center text-xs text-muted mb-10" aria-hidden="true">
      <!-- Empty placeholder for AdSense banner -->
    </div>

    <!-- Main Grid Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-10">
      <!-- Left side: Main Article Content -->
      <div class="lg:col-span-3 flex flex-col gap-8">
        <!-- Intro Paragraph -->
        <p class="text-[16px] md:text-[18px] text-body leading-relaxed font-normal" set:html={linkedIntro}></p>

        <!-- Sections -->
        {linkedSections.map((section) => (
          <section class="border-t border-hairline pt-8">
            <h2 class="text-2xl font-bold text-ink mb-4">{section.title}</h2>
            <p class="text-body-md text-body leading-relaxed mb-6" set:html={section.content}></p>

            <!-- Callout Box depending on type -->
            {section.boxText && (
              <div class={`p-5 rounded-md border text-[13.5px] leading-relaxed ${
                section.type === 'warning' ? 'bg-signature-cream/50 border-signature-cream text-ink' :
                section.type === 'success' || section.type === 'fact' ? 'bg-[#f4faf6] border-[#39bf45]/20 text-ink' :
                'bg-surface-soft border-hairline text-ink'
              }`}>
                <div class="flex gap-2.5 items-start">
                  <span class="text-base leading-none">
                    {section.type === 'warning' ? '⚠️' :
                     section.type === 'success' || section.type === 'fact' ? '💡' : 'ℹ️'}
                  </span>
                  <div>
                    <strong class="block text-ink font-semibold mb-0.5">
                      {section.type === 'warning' ? 'Critical Warning' :
                       section.type === 'success' || section.type === 'fact' ? 'Science Fact' : 'Safety Tip'}
                    </strong>
                    <span set:html={section.boxText} />
                  </div>
                </div>
              </div>
            )}
          </section>
        ))}

        <!-- Fallback Guides Section (to guarantee 10-link minimum) -->
        {fallbackGuides.length > 0 && (
          <section class="border-t border-hairline pt-8">
            <div class="bg-surface-soft border border-hairline rounded-md p-6">
              <h3 class="text-title-sm text-ink font-medium mb-3">📖 Referenced Appliance Safety Guides</h3>
              <p class="text-body-md text-muted mb-4 text-[13.5px]">Learn more about kitchen and appliance safety rules for these related items:</p>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                {fallbackGuides.map(g => (
                  <a href={g.url} class="text-[13px] text-link hover:underline font-medium">
                    Can you put {g.name.toLowerCase()} in the {g.appliance === 'airfryer' ? 'air fryer' : g.appliance}? &rarr;
                  </a>
                ))}
              </div>
            </div>
          </section>
        )}

        <!-- Conclusion -->
        <section class="border-t border-hairline pt-8 bg-surface-soft/40 p-6 rounded-lg">
          <h2 class="text-2xl font-bold text-ink mb-4">Conclusion</h2>
          <p class="text-body-md text-body leading-relaxed" set:html={linkedConclusion}></p>
        </section>

        <!-- FAQ Section -->
        <section class="border-t border-hairline pt-10">
          <h2 class="text-2xl md:text-3xl font-bold text-ink mb-6">Frequently Asked Questions</h2>
          <div class="flex flex-col">
            {article.faqs.map((faq) => (
              <details class="group border-b border-hairline py-4">
                <summary class="flex items-center justify-between text-title-sm text-ink font-medium cursor-pointer list-none [&::-webkit-details-marker]:hidden select-none">
                  <span>{faq.question}</span>
                  <span class="text-muted group-open:rotate-180 transition-transform duration-200">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                    </svg>
                  </span>
                </summary>
                <div class="mt-3 text-body-md text-body leading-relaxed pl-1">
                  {faq.answer}
                </div>
              </details>
            ))}
          </div>
        </section>

        <!-- Back to Blog Navigation -->
        <div class="mt-8 pt-8 border-t border-hairline flex justify-between items-center">
          <a href="/blog" class="text-link text-[14px] font-medium hover:text-link-active transition-colors">
            &larr; Back to Safety Blog
          </a>
          <a href="/" class="text-link text-[14px] font-medium hover:text-link-active transition-colors">
            Search Appliance Guides &rarr;
          </a>
        </div>
      </div>

      <!-- Right side: Sidebar -->
      <aside class="flex flex-col gap-8">
        <!-- Sidebar AdSense Placeholder -->
        <div class="ad-placeholder w-full h-[250px] bg-[#f8fafc] border border-dashed border-hairline flex items-center justify-center text-xs text-muted" aria-hidden="true">
          <!-- Empty placeholder for AdSense rectangle -->
        </div>

        <!-- Related Guides / Tools Link Box -->
        <div class="border border-hairline rounded-lg p-6 bg-canvas shadow-xs">
          <h3 class="text-title-sm text-ink font-bold mb-4">Related Safety Guides</h3>
          <ul class="flex flex-col gap-3">
            {article.relatedTools.map((tool) => (
              <li>
                <a 
                  href={tool.url} 
                  class="text-[13px] text-link hover:underline font-medium leading-normal block"
                >
                  {tool.name} &rarr;
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Relevant Comparisons Link Box -->
        {relevantComparisons.length > 0 && (
          <div class="border border-hairline rounded-lg p-6 bg-canvas shadow-xs">
            <h3 class="text-title-sm text-ink font-bold mb-4">Related Comparisons</h3>
            <ul class="flex flex-col gap-3">
              {relevantComparisons.map((c) => (
                <li>
                  <a 
                    href={`/compare/${c.slug}`} 
                    class="text-[13px] text-link hover:underline font-medium leading-normal block"
                  >
                    {c.item1} vs {c.item2} Guide &rarr;
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}

        <!-- Safety Pledge Trust Signals -->
        <div class="border border-hairline rounded-lg p-6 bg-[#fcfbfa]">
          <h4 class="text-xs uppercase tracking-wider text-muted font-bold mb-2">Our Safety Policy</h4>
          <p class="text-xs text-gray-500 leading-relaxed mb-3">
            Every guide is thoroughly researched using recommendations from the Food Safety and Inspection Service (FSIS), USDA, and FDA.
          </p>
          <span class="text-[10px] text-muted block">Last updated: June 2026</span>
        </div>

        <!-- Sidebar AdSense Bottom Placeholder -->
        <div class="ad-placeholder w-full h-[600px] bg-[#f8fafc] border border-dashed border-hairline flex items-center justify-center text-xs text-muted" aria-hidden="true">
          <!-- Empty placeholder for AdSense skyscraper -->
        </div>
      </aside>
    </div>

    <!-- Related Blog Articles Section -->
    <section class="border-t border-hairline pt-12 mt-12">
      <h2 class="text-2xl font-bold text-ink mb-8">Related Blog Articles</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {relatedArticles.map((art) => (
          <a 
            href={`/blog/${art.slug}`} 
            class="group bg-canvas border border-hairline hover:border-border-strong rounded-lg p-6 flex flex-col justify-between shadow-xs transition-colors active:scale-[0.98]"
          >
            <div>
              <span class="text-caption text-muted text-xs block mb-2">{art.date}</span>
              <h3 class="text-title-sm text-ink font-bold mb-3 leading-snug group-hover:text-link transition-colors">
                {art.title}
              </h3>
              <p class="text-[13px] text-muted line-clamp-3 leading-relaxed">
                {art.excerpt}
              </p>
            </div>
            <span class="text-[12px] font-medium text-link mt-4 block">Read article &rarr;</span>
          </a>
        ))}
      </div>
    </section>
  </article>
</Layout>
