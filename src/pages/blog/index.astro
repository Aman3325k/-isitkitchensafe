---
import Layout from '../../layouts/Layout.astro';
import blogData from '../../data/blog.json';

const pageTitle = "Kitchen Safety Blog | IsItKitchenSafe";
const pageDescription = "Explore expert kitchen safety guides, appliance tips, USDA/FDA food storage guidelines, and common kitchen myths debunked by our dedicated editorial team.";

const blogFaqs = [
  {
    question: "How long can leftovers safely stay in the refrigerator?",
    answer: "According to USDA guidelines, most cooked leftovers (such as poultry, meats, and soups) can be safely stored in the refrigerator for 3 to 4 days. Always reheat them to an internal temperature of 165°F before serving."
  },
  {
    question: "Why is it dangerous to microwave whole eggs?",
    answer: "Microwaving a whole egg in its shell builds up high steam pressure inside. Since the pressure cannot escape through the rigid shell, it can explode violently either inside the appliance or immediately after removal, causing severe steam burns."
  },
  {
    question: "Can you wash wooden cutting boards in the dishwasher?",
    answer: "No, wooden cutting boards should never go in the dishwasher. The high heat, moisture, and harsh detergents will warp, splinter, and crack the wood, creating crevices where bacteria can harbor."
  },
  {
    question: "Is it safe to refreeze raw meat that has thawed?",
    answer: "Raw meat (such as chicken or beef) can only be safely refrozen if it was thawed slowly inside a refrigerator below 40°F. If it was thawed on the counter or in warm water, bacterial multiplication makes refreezing dangerous."
  },
  {
    question: "What cookware materials are unsafe for oven use?",
    answer: "Cookware with plastic handles, wooden elements, thin non-tempered glass, or Teflon non-stick coatings heated above 500°F are unsafe for the oven. Reactive copper pans lined with tin also melt at 450°F and should be avoided."
  }
];
---

<Layout title={pageTitle} description={pageDescription} faqs={blogFaqs}>

  <section class="max-w-[1280px] mx-auto px-6 py-12">
    <!-- Breadcrumbs -->
    <nav class="flex gap-2 text-muted text-[13px] mb-8" aria-label="Breadcrumb">
      <a href="/" class="hover:text-ink transition-colors">Home</a>
      <span>/</span>
      <span class="text-ink font-medium">Blog</span>
    </nav>

    <!-- Header Section -->
    <header class="max-w-[800px] mb-12">
      <h1 class="text-4xl md:text-5xl font-bold text-ink tracking-tight mb-4">
        Kitchen Safety Blog
      </h1>
      <p class="text-body-md text-gray-500 text-lg leading-relaxed">
        Expert safety analyses, appliance guides, and food preservation advice based on USDA, FDA, and manufacturer guidelines.
      </p>
    </header>

    <!-- AdSense Placeholder -->
    <div class="ad-placeholder w-full h-[90px] bg-[#f8fafc] border border-dashed border-hairline flex items-center justify-center text-xs text-muted mb-12" aria-hidden="true">
      <!-- Empty placeholder for AdSense banner -->
    </div>

    <!-- Main Content Area with Sidebar Grid Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
      <!-- Article Cards Grid -->
      <div class="lg:col-span-3 grid grid-cols-1 md:grid-cols-2 gap-8">
        {blogData.map((article) => (
          <article class="bg-canvas border border-hairline rounded-lg shadow-sm hover:shadow-md transition-all duration-200 flex flex-col justify-between overflow-hidden">
            <div class="p-6">
              <span class="text-[11px] text-link uppercase tracking-wider font-bold block mb-2">
                Safety Guides
              </span>
              <h2 class="text-title-sm text-ink font-semibold mb-3 hover:text-link transition-colors">
                <a href={`/blog/${article.slug}`}>{article.title}</a>
              </h2>
              <p class="text-[14px] text-gray-500 leading-relaxed mb-4 line-clamp-3">
                {article.excerpt}
              </p>
            </div>
            <div class="px-6 pb-6 pt-4 border-t border-hairline bg-surface-soft flex items-center justify-between text-xs text-muted">
              <span>{article.date}</span>
              <span>{article.readTime}</span>
            </div>
          </article>
        ))}
      </div>

      <!-- Sidebar -->
      <aside class="flex flex-col gap-8">
        <!-- Sidebar AdSense Placeholder -->
        <div class="ad-placeholder w-full h-[250px] bg-[#f8fafc] border border-dashed border-hairline flex items-center justify-center text-xs text-muted" aria-hidden="true">
          <!-- Empty placeholder for AdSense rectangle -->
        </div>

        <!-- Trust Box -->
        <div class="bg-signature-cream/40 border border-signature-cream rounded-lg p-6">
          <h3 class="text-title-sm text-ink font-semibold mb-3">Verified Information</h3>
          <p class="text-[13px] text-gray-500 leading-relaxed mb-4">
            Our editorial team researches and publishes guides backed by official guidelines from the USDA, FDA, and leading appliance manufacturers.
          </p>
          <span class="text-xs text-success font-medium bg-[#e6f4ea] px-2.5 py-1 rounded-full inline-block">
            ✓ Science-Backed
          </span>
        </div>
      </aside>
    </div>

    <!-- AdSense Placeholder between sections -->
    <div class="ad-placeholder w-full h-[90px] bg-[#f8fafc] border border-dashed border-hairline flex items-center justify-center text-xs text-muted mt-16" aria-hidden="true">
      <!-- Empty placeholder for AdSense bottom banner -->
    </div>
  </section>
</Layout>
