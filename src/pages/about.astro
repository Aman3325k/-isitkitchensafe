---
import Layout from '../layouts/Layout.astro';

const pageTitle = "About Us | IsItKitchenSafe";
const pageDescription = "Learn about the mission, team, and scientific testing methodology behind IsItKitchenSafe, your trusted kitchen appliance compatibility and food safety guide.";

const aboutFaqs = [
  {
    question: "Why was IsItKitchenSafe created?",
    answer: "It was created to prevent accidental fires, ruined dinnerware, and damaged appliances by providing quick, straightforward, and research-backed answers to kitchen safety questions."
  },
  {
    question: "What do the YES, NO, and DEPENDS badges mean?",
    answer: "YES means the item is engineered to withstand the appliance. NO means it is dangerous or will ruin the item/appliance. DEPENDS means it is safe only under specific rules (like top rack or with food weight)."
  }
];

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "IsItKitchenSafe",
  "url": "https://isitkitchensafe.com",
  "logo": "https://isitkitchensafe.com/og-image.png",
  "description": "Kitchen safety reference site",
  "sameAs": []
};
---

<Layout title={pageTitle} description={pageDescription} faqs={aboutFaqs} excludeArticleSchema={true}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
  <section class="max-w-[800px] mx-auto px-6 py-[96px]">
    <h1 class="text-display-lg font-medium text-ink tracking-tight mb-8">About Is It Kitchen Safe?</h1>
    
    <div class="prose max-w-none text-body-md text-body leading-relaxed flex flex-col gap-6">
      <p class="text-title-md font-normal leading-relaxed text-ink">
        We make kitchen safety simple, quick, and reliable. No long-winded backstories, no clickbait—just immediate, research-backed answers to your "Can I put this in there?" questions.
      </p>

      <div class="border-t border-hairline my-6"></div>

      <h2 class="text-title-lg text-ink font-medium tracking-tight">Our Mission</h2>
      <p>
        Every year, thousands of kitchens suffer accidental fires, ruined appliances, and ruined dinnerware simply because someone wasn't sure if an item was safe for the microwave, dishwasher, oven, or freezer. 
      </p>
      <p>
        <strong>Is It Kitchen Safe?</strong> was created to serve as the ultimate, quick-reference static manual for the modern home cook. We provide instant, bulletproof yes/no verdicts so you can protect your appliances, keep your tableware intact, and ensure your home stays safe.
      </p>

      <h2 class="text-title-lg text-ink font-medium tracking-tight mt-4">Our Sourcing & Editorial Methodology</h2>
      <p>
        To ensure we provide the most accurate and safe guidelines for your kitchen, the <strong>IsItKitchenSafe Editorial Team</strong> adheres to a strict research and verification protocol. We do not make guesses; every recommendation is backed by a combination of official regulatory standards, material science research, and manufacturer specifications.
      </p>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 my-4 bg-surface-soft p-6 border border-hairline rounded-md">
        <div>
          <h3 class="text-title-sm font-semibold text-ink mb-2">Primary Sourcing Channels</h3>
          <ul class="list-disc pl-5 flex flex-col gap-1.5 text-[13px] text-body">
            <li><strong>Regulatory Agencies:</strong> We cross-reference all food preservation, shelf life, and freezing guidelines with the USDA Food Safety and Inspection Service (FSIS) and FDA guidelines.</li>
            <li><strong>Manufacturer Manuals:</strong> We catalog and verify appliance safety guidelines directly from manufacturer user manuals (e.g., Pyrex thermal limits, Corelle composition, Yeti or Hydro Flask insulated structures).</li>
          </ul>
        </div>
        <div>
          <h3 class="text-title-sm font-semibold text-ink mb-2">Scientific Testing Criteria</h3>
          <ul class="list-disc pl-5 flex flex-col gap-1.5 text-[13px] text-body">
            <li><strong>Material Science:</strong> We evaluate how materials respond to thermal stress, electromagnetic radiation (microwaves), vacuum sealing, and high-pressure water jets.</li>
            <li><strong>Chemical Leaching:</strong> We assess toxicity risks under high heat, such as BPA release in plastics or corrosion hazards with specific detergents.</li>
          </ul>
        </div>
      </div>

      <p>
        We classify every item under one of three statuses:
      </p>
      <ul class="list-disc pl-5 flex flex-col gap-2">
        <li>
          <strong class="text-success">YES:</strong> The item is engineered to withstand the specific environment without risk of physical damage, toxicity, or safety hazards.
        </li>
        <li>
          <strong class="text-signature-coral">NO:</strong> Placing the item in the appliance is dangerous, poses a fire/health hazard, or will permanently ruin the item or appliance.
        </li>
        <li>
          <strong class="text-signature-mustard">DEPENDS:</strong> The item is safe only under specific conditions (e.g. top rack only, weighted down by food, or carrying a specific manufacturer label).
        </li>
      </ul>

      <div class="bg-signature-cream/40 border border-signature-cream rounded-md p-6 mt-6">
        <h3 class="text-title-sm text-ink font-medium mb-2">Important Disclaimer</h3>
        <p class="text-[13px] text-muted leading-relaxed">
          While we research and verify every guide meticulously, products and materials vary by brand and year. When in doubt, always prioritize the official guidelines printed on the bottom of your cookware or listed in your appliance's manufacturer manual.
        </p>
      </div>
    </div>
  </section>
</Layout>
