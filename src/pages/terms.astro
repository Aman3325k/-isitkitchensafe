---
import Layout from '../layouts/Layout.astro';

const pageTitle = "Terms & Conditions | IsItKitchenSafe";
const pageDescription = "Read the Terms & Conditions for IsItKitchenSafe. Learn about our website usage rules, liability disclaimers, and user guidelines.";

const termsFaqs = [
  {
    question: "Are the kitchen safety guides on this website absolute safety rules?",
    questionSlug: "are-guides-absolute",
    answer: "No. The safety information provided is for general reference only. You should always consult your appliance's official manufacturer guidelines first."
  },
  {
    question: "Can I copy the safety guides from this site?",
    questionSlug: "can-i-copy-guides",
    answer: "No. The structure, compiled data, text, and layout are protected by intellectual property laws and cannot be copied without permission."
  }
];
---

<Layout title={pageTitle} description={pageDescription} faqs={termsFaqs} excludeArticleSchema={true}>
  <section class="max-w-[800px] mx-auto px-6 py-[96px]">
    <h1 class="text-display-lg font-medium text-ink tracking-tight mb-8">Terms & Conditions</h1>
    
    <div class="prose max-w-none text-body-md text-body leading-relaxed flex flex-col gap-6">
      <p class="text-muted text-[13px]">Last updated: June 19, 2026</p>

      <p>
        Welcome to <strong>Is It Kitchen Safe?</strong> (accessible from isitkitchensafe.com). By accessing or using our website, you agree to comply with and be bound by the following Terms & Conditions. If you do not agree to these terms, please do not use our website.
      </p>

      <div class="border-t border-hairline my-4"></div>

      <h2 class="text-title-lg text-ink font-medium tracking-tight">1. Use of the Website</h2>
      <p>
        The content on isitkitchensafe.com is provided for general informational and reference purposes only. You agree to use the site only for lawful purposes and in a way that does not infringe the rights of, restrict, or inhibit anyone else's use and enjoyment of the website.
      </p>

      <h2 class="text-title-lg text-ink font-medium tracking-tight">2. Disclaimer of Warranties</h2>
      <p>
        All information on this site is provided "as is" and "as available" without warranties of any kind, either express or implied. While we strive to present accurate, up-to-date safety data regarding kitchen materials and appliances, <strong>Is It Kitchen Safe?</strong> does not guarantee that the information is 100% complete, accurate, or free from error.
      </p>
      <p class="italic font-medium">
        Important: Kitchen appliance specifications vary by manufacturer and model. Always check the official manufacturer manual or label on your cookware, utensils, and appliances before putting them to use.
      </p>

      <h2 class="text-title-lg text-ink font-medium tracking-tight">3. Limitation of Liability</h2>
      <p>
        Under no circumstances shall isitkitchensafe.com, its owners, or its contributors be liable for any direct, indirect, incidental, special, or consequential damages (including, but not limited to, property damage, appliance malfunction, fire, bodily injury, or loss of food/data) resulting from your reliance on the safety guidelines provided on this site. You assume full responsibility for your kitchen safety decisions.
      </p>

      <h2 class="text-title-lg text-ink font-medium tracking-tight">4. Intellectual Property</h2>
      <p>
        The database, compiled safety guides, articles, text, site layout, graphics, and design are the intellectual property of <strong>Is It Kitchen Safe?</strong>. Unauthorized reproduction, scraping, copying, or redistribution of this content is strictly prohibited.
      </p>

      <h2 class="text-title-lg text-ink font-medium tracking-tight">5. Third-Party Links & Advertisements</h2>
      <p>
        Our website displays advertisements via Google AdSense and contains links to other external web resources. We do not control, endorse, or assume responsibility for the content, privacy policies, or practices of any third-party websites or services.
      </p>

      <h2 class="text-title-lg text-ink font-medium tracking-tight">6. Changes to Terms</h2>
      <p>
        We reserve the right to revise or replace these Terms & Conditions at any time. Any changes will be posted on this page with an updated "Last updated" date. Continued use of the website after changes are posted constitutes acceptance of the new terms.
      </p>

      <h2 class="text-title-lg text-ink font-medium tracking-tight">7. Contact Us</h2>
      <p>
        If you have any questions about these Terms & Conditions, please contact us by email at <a href="mailto:support@isitkitchensafe.com" class="text-link hover:underline">support@isitkitchensafe.com</a>.
      </p>
    </div>
  </section>
</Layout>
