---
import Layout from '../layouts/Layout.astro';
import itemsData from '../data/items.json';

// Popular items to showcase on the homepage
const popularSlugs = [
  'hydroflask',
  'styrofoam',
  'avocado',
  'parchment-paper',
  'crocs',
  'raw-chicken'
];

const popularItems = itemsData.filter(item => popularSlugs.includes(item.slug));

const searchItems = itemsData.map(item => ({
  name: item.item,
  appliance: item.appliance,
  url: `/${item.appliance}/${item.slug}`
}));

const appliances = [
  { 
    name: 'Dishwasher', 
    slug: 'dishwasher', 
    desc: 'Can you wash cast iron, vacuum flasks, and blender lids?',
    bgColor: 'bg-signature-forest', 
    textColor: 'text-on-primary',
    badgeColor: 'bg-[#e6f4ea] text-success'
  },
  { 
    name: 'Microwave', 
    slug: 'microwave', 
    desc: 'Is Styrofoam, aluminum foil, or paper plates safe to heat?',
    bgColor: 'bg-signature-coral', 
    textColor: 'text-on-primary',
    badgeColor: 'bg-[#fce8e6] text-signature-coral'
  },
  { 
    name: 'Freezer', 
    slug: 'freezer', 
    desc: 'What happens if you freeze milk, avocados, or carbonated soda?',
    bgColor: 'bg-signature-cream', 
    textColor: 'text-ink',
    badgeColor: 'bg-[#fef7e0] text-signature-mustard'
  },
  { 
    name: 'Oven', 
    slug: 'oven', 
    desc: 'Baking with parchment paper, wax paper, glass, or plastic?',
    bgColor: 'bg-signature-peach', 
    textColor: 'text-ink',
    badgeColor: 'bg-[#e6f4ea] text-success'
  },
  { 
    name: 'Dryer', 
    slug: 'dryer', 
    desc: 'Will shoes, Crocs, pillows, or wool shrink in the dryer?',
    bgColor: 'bg-signature-mint', 
    textColor: 'text-ink',
    badgeColor: 'bg-[#fce8e6] text-signature-coral'
  },
  { 
    name: 'Air Fryer', 
    slug: 'airfryer', 
    desc: 'Can you use foil, parchment paper, or cook raw chicken?',
    bgColor: 'bg-signature-yellow', 
    textColor: 'text-ink',
    badgeColor: 'bg-[#fef7e0] text-signature-mustard'
  },
  { 
    name: 'Refrigerator', 
    slug: 'refrigerator', 
    desc: 'Should you store potatoes, onions, honey, or tomatoes in the cold?',
    bgColor: 'bg-signature-mustard', 
    textColor: 'text-on-primary',
    badgeColor: 'bg-[#fce8e6] text-signature-coral'
  }
];
const homeFaqs = [
  {
    question: "What is IsItKitchenSafe?",
    answer: "IsItKitchenSafe is a static reference database that helps home cooks quickly determine whether everyday kitchenware, containers, and food items can be safely used in various household appliances."
  },
  {
    question: "Which appliances are covered on this site?",
    answer: "We cover seven major kitchen appliances: the dishwasher, microwave, freezer, oven, dryer, air fryer, and refrigerator."
  },
  {
    question: "How is the safety information verified?",
    answer: "Our recommendations are compiled from material science guidelines, official manufacturer manuals (such as Yeti, Pyrex, and Hydro Flask), FDA safety standards, and kitchen safety principles."
  }
];
---

<Layout 
  title="IsItKitchenSafe - Quick Safety Guides for Kitchen Appliances" 
  description="Search and browse over 500 kitchen safety guides. Find out whether you can put cookware, containers, or ingredients in the microwave, dishwasher, freezer, and oven."
  faqs={homeFaqs}
>
  <!-- Hero Section (Clean canvas, generous whitespace) -->
  <section class="bg-canvas border-b border-hairline py-[80px] md:py-[96px]">
    <div class="max-w-[800px] mx-auto px-6 text-center flex flex-col items-center">
      <h1 class="text-display-lg md:text-display-xl font-medium tracking-tight text-ink mb-6">
        Can you put it in the...
      </h1>
      <p class="text-body-md text-muted max-w-[580px] mb-8 leading-relaxed">
        Avoid melted plastic, shattered glass, and house fires. Search for everyday kitchen items to see if they are safe for your microwave, dishwasher, oven, freezer, dryer, air fryer, or refrigerator.
      </p>

      <!-- Static Search Bar -->
      <form id="search-form" class="w-full max-w-[600px] flex flex-col sm:flex-row gap-3">
        <div class="relative flex-grow">
          <input 
            type="text" 
            id="search-input" 
            placeholder="Type an item (e.g. Hydro Flask, Styrofoam, Parchment Paper)..." 
            list="search-items"
            autocomplete="off"
            class="w-full h-11 px-4 py-3 bg-canvas text-ink text-[14px] border border-hairline rounded-sm focus:outline-none focus:border-info-border"
          />
          <!-- Datalist holding all 50 items -->
          <datalist id="search-items">
            {itemsData.map(entry => (
              <option value={`${entry.item} (${entry.appliance})`} data-url={`/${entry.appliance}/${entry.slug}`} />
            ))}
          </datalist>
        </div>
        <button 
          type="submit" 
          class="h-11 px-6 bg-primary hover:bg-primary-active text-on-primary text-[14px] font-medium rounded-sm border-none cursor-pointer flex items-center justify-center transition-colors select-none"
        >
          Check Safety
        </button>
      </form>
    </div>
  </section>

  <!-- Browse by Appliance (Airtable-style signature cards) -->
  <section class="max-w-[1280px] mx-auto px-6 py-[96px]">
    <div class="mb-12">
      <h2 class="text-display-md text-ink tracking-tight mb-3">Browse by Appliance</h2>
      <p class="text-body-md text-muted">Select an appliance to explore all safety guides and rules.</p>
    </div>

    <!-- Responsive Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {appliances.map(app => (
        <a 
          href={`/${app.slug}`} 
          class={`${app.bgColor} ${app.textColor} rounded-lg p-8 flex flex-col justify-between min-h-[200px] shadow-sm transition-transform active:scale-[0.98] border border-transparent`}
        >
          <div>
            <span class="text-caption font-semibold tracking-wider uppercase opacity-75 mb-2 block">Safety Guide</span>
            <h3 class="text-title-lg font-medium tracking-tight mb-3">{app.name}</h3>
            <p class="text-body-md opacity-85 leading-relaxed mb-6">{app.desc}</p>
          </div>
          <span class="text-[14px] font-medium underline underline-offset-4 flex items-center gap-1">
            View all {itemsData.filter(i => i.appliance === app.slug).length} items &rarr;
          </span>
        </a>
      ))}
    </div>
  </section>

  <!-- Most Searched Guides (Cream Callout & Article Grid) -->
  <section class="bg-surface-soft border-t border-b border-hairline py-[96px]">
    <div class="max-w-[1280px] mx-auto px-6">
      <div class="mb-12 text-center md:text-left">
        <h2 class="text-display-md text-ink tracking-tight mb-3">Frequently Searched Questions</h2>
        <p class="text-body-md text-muted">Get immediate answers to some of the most common kitchen safety dilemmas.</p>
      </div>

      <!-- Grid of Popular Items -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {popularItems.map(item => (
          <div class="bg-canvas border border-hairline rounded-md p-6 flex flex-col justify-between shadow-xs transition-shadow">
            <div>
              <div class="flex items-center justify-between mb-4">
                <span class="text-caption text-muted uppercase tracking-wider text-xs">{item.appliance}</span>
                {item.safe === 'yes' && <span class="badge-yes">YES</span>}
                {item.safe === 'no' && <span class="badge-no">NO</span>}
                {item.safe === 'depends' && <span class="badge-depends">DEPENDS</span>}
              </div>
              <h3 class="text-title-sm text-ink mb-3">
                Can You Put {item.item} in the {item.appliance === 'airfryer' ? 'Air Fryer' : item.appliance.charAt(0).toUpperCase() + item.appliance.slice(1)}?
              </h3>
              <p class="text-body-md text-body leading-relaxed mb-6">
                {item.shortAnswer}
              </p>
            </div>
            <a 
              href={`/${item.appliance}/${item.slug}`} 
              class="text-link text-[14px] font-medium hover:text-link-active transition-colors flex items-center gap-1 group"
            >
              Read full explanation <span class="group-hover:translate-x-0.5 transition-transform">&rarr;</span>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <script define:vars={{ searchItems }}>
    const searchForm = document.getElementById('search-form');
    const searchInput = document.getElementById('search-input');

    if (searchForm && searchInput) {
      searchForm.addEventListener('submit', (e) => {
        e.preventDefault();
        const rawValue = searchInput.value.trim().toLowerCase();
        if (!rawValue) return;

        // 1. Try exact match on item name
        let match = searchItems.find(item => item.name.toLowerCase() === rawValue);

        // 2. Try matching the full value that datalist might output (e.g. "Hydro Flask (dishwasher)")
        if (!match) {
          match = searchItems.find(item => {
            const displayVal = `${item.name} (${item.appliance})`.toLowerCase();
            return displayVal === rawValue;
          });
        }

        // 3. Try partial match on item name
        if (!match) {
          match = searchItems.find(item => item.name.toLowerCase().includes(rawValue));
        }

        // 4. Try matching appliance names
        if (!match) {
          const applianceMap = {
            'dishwasher': '/dishwasher',
            'microwave': '/microwave',
            'freezer': '/freezer',
            'oven': '/oven',
            'dryer': '/dryer',
            'air fryer': '/airfryer',
            'airfryer': '/airfryer',
            'refrigerator': '/refrigerator',
            'fridge': '/refrigerator'
          };
          if (applianceMap[rawValue]) {
            window.location.href = applianceMap[rawValue];
            return;
          }
        }

        if (match) {
          window.location.href = match.url;
        } else {
          alert(`We couldn't find a direct guide for "${searchInput.value}". Please select from the suggestions list or browse by appliance below!`);
        }
      });
    }
  </script>
</Layout>
