---
import Layout from '../layouts/Layout.astro';
import itemsData from '../data/items.json';

// Popular items to showcase on the homepage
const popularCombos = [
  { slug: 'hydroflask', appliance: 'dishwasher' },
  { slug: 'styrofoam', appliance: 'microwave' },
  { slug: 'avocado', appliance: 'freezer' },
  { slug: 'parchment-paper', appliance: 'airfryer' },
  { slug: 'crocs', appliance: 'dryer' },
  { slug: 'raw-chicken', appliance: 'freezer' },
  { slug: 'cast-iron-skillet', appliance: 'dishwasher' },
  { slug: 'chefs-knife', appliance: 'dishwasher' },
  { slug: 'aluminum-foil', appliance: 'microwave' },
  { slug: 'stanley-cup', appliance: 'dishwasher' }
];

const popularItems = itemsData.filter(item => 
  popularCombos.some(combo => combo.slug === item.slug && combo.appliance === item.appliance)
);

// Helper to format appliance names for output
function formatAppliance(app: string) {
  if (app === 'airfryer') return 'Air Fryer';
  return app.charAt(0).toUpperCase() + app.slice(1);
}

const appliances = [
  { 
    name: 'Dishwasher', 
    slug: 'dishwasher', 
    desc: 'Can you wash cast iron, vacuum flasks, and blender lids?',
    bgColor: 'bg-signature-forest', 
    textColor: 'text-on-primary',
    badgeColor: 'bg-[#e6f4ea] text-success'
  },
  { 
    name: 'Microwave', 
    slug: 'microwave', 
    desc: 'Is Styrofoam, aluminum foil, or paper plates safe to heat?',
    bgColor: 'bg-signature-coral', 
    textColor: 'text-on-primary',
    badgeColor: 'bg-[#fce8e6] text-signature-coral'
  },
  { 
    name: 'Freezer', 
    slug: 'freezer', 
    desc: 'What happens if you freeze milk, avocados, or carbonated soda?',
    bgColor: 'bg-signature-cream', 
    textColor: 'text-ink',
    badgeColor: 'bg-[#fef7e0] text-signature-mustard'
  },
  { 
    name: 'Oven', 
    slug: 'oven', 
    desc: 'Baking with parchment paper, wax paper, glass, or plastic?',
    bgColor: 'bg-signature-peach', 
    textColor: 'text-ink',
    badgeColor: 'bg-[#e6f4ea] text-success'
  },
  { 
    name: 'Dryer', 
    slug: 'dryer', 
    desc: 'Will shoes, Crocs, pillows, or wool shrink in the dryer?',
    bgColor: 'bg-signature-mint', 
    textColor: 'text-ink',
    badgeColor: 'bg-[#fce8e6] text-signature-coral'
  },
  { 
    name: 'Air Fryer', 
    slug: 'airfryer', 
    desc: 'Can you use foil, parchment paper, or cook raw chicken?',
    bgColor: 'bg-signature-yellow', 
    textColor: 'text-ink',
    badgeColor: 'bg-[#fef7e0] text-signature-mustard'
  },
  { 
    name: 'Refrigerator', 
    slug: 'refrigerator', 
    desc: 'Should you store potatoes, onions, honey, or tomatoes in the cold?',
    bgColor: 'bg-signature-mustard', 
    textColor: 'text-ink',
    badgeColor: 'bg-[#fce8e6] text-signature-coral'
  }
];

const homeFaqs = [
  {
    question: "What is IsItKitchenSafe?",
    answer: "IsItKitchenSafe is a static reference database that helps home cooks quickly determine whether everyday kitchenware, containers, and food items can be safely used in various household appliances."
  },
  {
    question: "Which appliances are covered on this site?",
    answer: "We cover seven major kitchen appliances: the dishwasher, microwave, freezer, oven, dryer, air fryer, and refrigerator."
  },
  {
    question: "How is the safety information verified?",
    answer: "Our recommendations are compiled from material science guidelines, official manufacturer manuals (such as Yeti, Pyrex, and Hydro Flask), FDA safety standards, and kitchen safety principles."
  }
];
---

<Layout 
  title="IsItKitchenSafe - Quick Safety Guides for Kitchen Appliances" 
  description="Search and browse 2,000+ kitchen safety guides. Find out if you can put cookware, containers, or ingredients in the microwave, dishwasher, freezer, and oven."
  faqs={homeFaqs}
  excludeArticleSchema={true}
>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "IsItKitchenSafe",
      "url": "https://isitkitchensafe.com",
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "https://isitkitchensafe.com/search?q={search_term_string}"
        },
        "query-input": "required name=search_term_string"
      }
    })} />
  </Fragment>
  <!-- Hero Section (Clean canvas, generous whitespace) -->
  <section class="bg-canvas border-b border-hairline py-[80px] md:py-[96px]">
    <div class="max-w-[800px] mx-auto px-6 text-center flex flex-col items-center">
      <h1 class="text-display-lg md:text-display-xl font-medium tracking-tight text-ink mb-6">
        Can you put it in the...
      </h1>
      <p class="text-body-md text-muted max-w-[580px] mb-8 leading-relaxed">
        Avoid melted plastic, shattered glass, and house fires. Search over 2,000+ everyday kitchen items to see if they are safe for your microwave, dishwasher, oven, freezer, dryer, air fryer, or refrigerator.
      </p>

      <!-- Static Search Bar -->
      <form id="search-form" class="w-full max-w-[600px] flex flex-col sm:flex-row gap-3">
        <div class="relative flex-grow">
          <input 
            type="text" 
            id="search-input" 
            placeholder="Type an item (e.g. Hydro Flask, Chicken, Memory Foam)..." 
            list="search-items"
            autocomplete="off"
            aria-label="Search items"
            class="w-full h-11 pl-4 pr-10 py-3 bg-canvas text-ink text-[14px] border border-hairline rounded-sm focus:outline-none focus:border-info-border"
          />
          <datalist id="search-items"></datalist>
          <div id="search-loading" class="hidden absolute right-3.5 top-1/2 -translate-y-1/2">
            <svg class="animate-spin h-5 w-5 text-muted" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
          </div>
        </div>
        <button 
          type="submit" 
          class="h-11 px-6 bg-primary hover:bg-primary-active text-on-primary text-[14px] font-medium rounded-sm border-none cursor-pointer flex items-center justify-center transition-colors select-none"
        >
          Check Safety
        </button>
      </form>
    </div>
  </section>

  <!-- Browse by Appliance (Airtable-style signature cards) -->
  <section class="max-w-[1280px] mx-auto px-6 pt-[96px] pb-12">
    <div class="mb-12">
      <h2 class="text-display-md text-ink tracking-tight mb-3">Browse by Appliance</h2>
      <p class="text-body-md text-muted">Select an appliance to explore all safety guides and rules.</p>
    </div>

    <!-- Responsive Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {appliances.map(app => (
        <a 
          href={`/${app.slug}`} 
          class={`${app.bgColor} ${app.textColor} rounded-lg p-8 flex flex-col justify-between min-h-[200px] shadow-sm transition-transform active:scale-[0.98] border border-transparent`}
        >
          <div>
            <span class="text-caption font-semibold tracking-wider uppercase opacity-75 mb-2 block">Safety Guide</span>
            <h3 class="text-title-lg font-medium tracking-tight mb-3">{app.name}</h3>
            <p class="text-body-md opacity-85 leading-relaxed mb-6">{app.desc}</p>
          </div>
          <span class="text-[14px] font-medium underline underline-offset-4 flex items-center gap-1">
            View all {itemsData.filter(i => i.appliance === app.slug).length} items &rarr;
          </span>
        </a>
      ))}
    </div>
  </section>

  <!-- Browse by Safety Category (Airtable-style signature cards) -->
  <section class="max-w-[1280px] mx-auto px-6 pb-[96px]">
    <div class="mb-12 border-t border-hairline pt-[96px]">
      <h2 class="text-display-md text-ink tracking-tight mb-3">Browse by Safety Category</h2>
      <p class="text-body-md text-muted">Explore shelf life, material cleaning, and prevention guidelines.</p>
    </div>

    <!-- Responsive Grid of 6 Category/Directory Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <a 
        href="/how-long" 
        class="bg-signature-forest text-on-primary rounded-lg p-8 flex flex-col justify-between min-h-[220px] shadow-sm transition-transform active:scale-[0.98] border border-transparent"
      >
        <div>
          <span class="text-caption font-semibold tracking-wider uppercase opacity-75 mb-2 block">Storage Safety</span>
          <h3 class="text-title-lg font-medium tracking-tight mb-3">Food Shelf Life</h3>
          <p class="text-body-md opacity-85 leading-relaxed mb-6">How long do raw meats, leftovers, dairy, and produce stay safe in the fridge, freezer, or pantry?</p>
        </div>
        <span class="text-[14px] font-medium underline underline-offset-4 flex items-center gap-1">
          View all 150 guides &rarr;
        </span>
      </a>

      <a 
        href="/washing-machine" 
        class="bg-signature-coral text-on-primary rounded-lg p-8 flex flex-col justify-between min-h-[220px] shadow-sm transition-transform active:scale-[0.98] border border-transparent"
      >
        <div>
          <span class="text-caption font-semibold tracking-wider uppercase opacity-75 mb-2 block">Fabric Care</span>
          <h3 class="text-title-lg font-medium tracking-tight mb-3">Washing Machine</h3>
          <p class="text-body-md opacity-85 leading-relaxed mb-6">Can you wash sneakers, pillows, bedding, or down jackets in the washing machine?</p>
        </div>
        <span class="text-[14px] font-medium underline underline-offset-4 flex items-center gap-1">
          View all 80 guides &rarr;
        </span>
      </a>

      <a 
        href="/refreeze" 
        class="bg-signature-cream text-ink rounded-lg p-8 flex flex-col justify-between min-h-[220px] shadow-sm transition-transform active:scale-[0.98] border border-transparent"
      >
        <div>
          <span class="text-caption font-semibold tracking-wider uppercase opacity-75 mb-2 block">Temperature Rules</span>
          <h3 class="text-title-lg font-medium tracking-tight mb-3">Refreeze Safety</h3>
          <p class="text-body-md opacity-85 leading-relaxed mb-6">Is it safe to refreeze chicken, beef, or dairy once thawed? Get the absolute USDA safety rules.</p>
        </div>
        <span class="text-[14px] font-medium underline underline-offset-4 flex items-center gap-1 text-ink">
          View all 80 guides &rarr;
        </span>
      </a>

      <a 
        href="/what-happens" 
        class="bg-[#181d26] text-on-dark rounded-lg p-8 flex flex-col justify-between min-h-[220px] shadow-sm transition-transform active:scale-[0.98] border border-transparent"
      >
        <div>
          <span class="text-caption font-semibold tracking-wider uppercase opacity-75 mb-2 block">Accident Prevention</span>
          <h3 class="text-title-lg font-medium tracking-tight mb-3">What Happens If</h3>
          <p class="text-body-md opacity-85 leading-relaxed mb-6">Explore the danger levels and physical results of microwaving foil, leaving ovens on, or mixing chemicals.</p>
        </div>
        <span class="text-[14px] font-medium underline underline-offset-4 flex items-center gap-1 text-white">
          View all 60 guides &rarr;
        </span>
      </a>

      <a 
        href="/compare" 
        class="bg-signature-yellow text-ink rounded-lg p-8 flex flex-col justify-between min-h-[220px] shadow-sm transition-transform active:scale-[0.98] border border-transparent"
      >
        <div>
          <span class="text-caption font-semibold tracking-wider uppercase opacity-75 mb-2 block">Product Face-offs</span>
          <h3 class="text-title-lg font-medium tracking-tight mb-3">Safety Comparisons</h3>
          <p class="text-body-md opacity-85 leading-relaxed mb-6">Side-by-side kitchen safety reviews (e.g. foil vs parchment paper, cast iron vs stainless steel).</p>
        </div>
        <span class="text-[14px] font-medium underline underline-offset-4 flex items-center gap-1 text-ink">
          View 50 comparisons &rarr;
        </span>
      </a>

      <a 
        href="/blog" 
        class="bg-signature-mint text-ink rounded-lg p-8 flex flex-col justify-between min-h-[220px] shadow-sm transition-transform active:scale-[0.98] border border-transparent"
      >
        <div>
          <span class="text-caption font-semibold tracking-wider uppercase opacity-75 mb-2 block">Safety Science</span>
          <h3 class="text-title-lg font-medium tracking-tight mb-3">Kitchen Safety Blog</h3>
          <p class="text-body-md opacity-85 leading-relaxed mb-6">Deep dives, news reports, and detailed articles examining materials and food handling rules.</p>
        </div>
        <span class="text-[14px] font-medium underline underline-offset-4 flex items-center gap-1 text-ink">
          Read articles &rarr;
        </span>
      </a>
    </div>
  </section>
  </section>

  <!-- How It Works & Why Trust Us Sections -->
  <section class="bg-canvas border-t border-hairline py-[96px]">
    <div class="max-w-[1280px] mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-16">
      <!-- How It Works -->
      <div>
        <h2 class="text-display-md text-ink tracking-tight mb-6">How It Works</h2>
        <div class="flex flex-col gap-6">
          <div class="flex gap-4 items-start">
            <span class="w-8 h-8 rounded-full bg-primary/5 text-primary flex items-center justify-center font-bold text-sm shrink-0">1</span>
            <div>
              <h3 class="text-title-sm text-ink font-semibold mb-1">Search or Browse</h3>
              <p class="text-[13.5px] text-muted leading-relaxed">
                Type any item (like "parchment paper" or "Crocs") in the search bar or choose one of the appliance categories to view the full database.
              </p>
            </div>
          </div>
          <div class="flex gap-4 items-start">
            <span class="w-8 h-8 rounded-full bg-primary/5 text-primary flex items-center justify-center font-bold text-sm shrink-0">2</span>
            <div>
              <h3 class="text-title-sm text-ink font-semibold mb-1">Check the Verdict Badge</h3>
              <p class="text-[13.5px] text-muted leading-relaxed">
                Every page features a clear YES, NO, or DEPENDS safety badge above the fold, providing an immediate answer to your question.
              </p>
            </div>
          </div>
          <div class="flex gap-4 items-start">
            <span class="w-8 h-8 rounded-full bg-primary/5 text-primary flex items-center justify-center font-bold text-sm shrink-0">3</span>
            <div>
              <h3 class="text-title-sm text-ink font-semibold mb-1">Read Science-Backed Details</h3>
              <p class="text-[13.5px] text-muted leading-relaxed">
                Understand the potential risks, manufacturer specifications, temperature limits, and cleaning guidelines based on official safety standards.
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Why Trust Us -->
      <div>
        <h2 class="text-display-md text-ink tracking-tight mb-6">Why Trust Us?</h2>
        <div class="flex flex-col gap-6">
          <div class="flex gap-4 items-start">
            <span class="w-8 h-8 rounded-full bg-[#e6f4ea] text-success flex items-center justify-center font-bold text-sm shrink-0 select-none">✓</span>
            <div>
              <h3 class="text-title-sm text-ink font-semibold mb-1">Backed by USDA & FDA Guidelines</h3>
              <p class="text-[13.5px] text-muted leading-relaxed">
                Our food storage, refreeze, and appliance instructions strictly adhere to safety publications from the USDA and the FDA.
              </p>
            </div>
          </div>
          <div class="flex gap-4 items-start">
            <span class="w-8 h-8 rounded-full bg-[#e6f4ea] text-success flex items-center justify-center font-bold text-sm shrink-0 select-none">✓</span>
            <div>
              <h3 class="text-title-sm text-ink font-semibold mb-1">Zero Placeholder Content</h3>
              <p class="text-[13.5px] text-muted leading-relaxed">
                We believe in providing exact, high-fidelity information. Every recommendation is compiled from manufacturer manuals and chemical safety data sheets.
              </p>
            </div>
          </div>
          <div class="flex gap-4 items-start">
            <span class="w-8 h-8 rounded-full bg-[#e6f4ea] text-success flex items-center justify-center font-bold text-sm shrink-0 select-none">✓</span>
            <div>
              <h3 class="text-title-sm text-ink font-semibold mb-1">Editorial Integrity</h3>
              <p class="text-[13.5px] text-muted leading-relaxed">
                Our guides are updated regularly to reflect the latest safety recalls and manufacturer design changes, keeping your home and family safe.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Most Searched Guides (Cream Callout & Article Grid) -->
  <section class="bg-surface-soft border-t border-b border-hairline py-[96px]">
    <div class="max-w-[1280px] mx-auto px-6">
      <div class="mb-12 text-center md:text-left">
        <h2 class="text-display-md text-ink tracking-tight mb-3">Frequently Searched Questions</h2>
        <p class="text-body-md text-muted">Get immediate answers to some of the most common kitchen safety dilemmas.</p>
      </div>

      <!-- Grid of Popular Items -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {popularItems.map(item => (
          <div class="bg-canvas border border-hairline rounded-md p-6 flex flex-col justify-between shadow-xs transition-shadow">
            <div>
              <div class="flex items-center justify-between mb-4">
                <span class="text-caption text-muted uppercase tracking-wider text-xs">{formatAppliance(item.appliance)}</span>
                {item.safe === 'yes' && <span class="badge-yes">YES</span>}
                {item.safe === 'no' && <span class="badge-no">NO</span>}
                {item.safe === 'depends' && <span class="badge-depends">DEPENDS</span>}
              </div>
              <h3 class="text-title-sm text-ink mb-3">
                Can You Put {item.item} in the {formatAppliance(item.appliance)}?
              </h3>
              <p class="text-body-md text-body leading-relaxed mb-6">
                {item.shortAnswer}
              </p>
            </div>
            <a 
              href={`/${item.appliance}/${item.slug}`} 
              class="text-link text-[14px] font-medium hover:text-link-active transition-colors flex items-center gap-1 group"
            >
              Read full explanation <span class="group-hover:translate-x-0.5 transition-transform">&rarr;</span>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const searchForm = document.getElementById('search-form') as HTMLFormElement | null;
      const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
      const datalist = document.getElementById('search-items') as HTMLDataListElement | null;
      const searchLoading = document.getElementById('search-loading');
      let searchIndex: Array<{ name: string; appliance: string; url: string }> | null = null;
      let isFetching = false;

      const populateDatalist = (items: typeof searchIndex) => {
        if (!datalist || !items) return;
        datalist.innerHTML = items.map(entry => 
          `<option value="${entry.name} (${entry.appliance})" data-url="${entry.url}"></option>`
        ).join('');
      };

      const loadSearchIndex = async () => {
        if (searchIndex || isFetching) return;
        isFetching = true;
        if (searchLoading) searchLoading.classList.remove('hidden');
        try {
          const response = await fetch('/search-index.json');
          if (response.ok) {
            const rawIndex = await response.json();
            searchIndex = rawIndex.map((entry: any) => ({
              name: entry.name,
              appliance: entry.category,
              url: entry.url
            }));
            populateDatalist(searchIndex);
          }
        } catch (e) {
          // Silently fail to maintain UX
        } finally {
          isFetching = false;
          if (searchLoading) searchLoading.classList.add('hidden');
        }
      };

      if (searchInput) {
        searchInput.addEventListener('focus', loadSearchIndex);
        searchInput.addEventListener('input', loadSearchIndex);
      }

      if (searchForm && searchInput) {
        searchForm.addEventListener('submit', (e) => {
          e.preventDefault();
          const rawValue = searchInput.value.trim().toLowerCase();
          if (!rawValue || !searchIndex) return;

          let match = searchIndex.find(item => item.name.toLowerCase() === rawValue);

          if (!match) {
            match = searchIndex.find(item => {
              const displayVal = `${item.name} (${item.appliance})`.toLowerCase();
              return displayVal === rawValue;
            });
          }

          if (!match) {
            match = searchIndex.find(item => item.name.toLowerCase().includes(rawValue));
          }

          if (!match) {
            const applianceMap: Record<string, string> = {
              'dishwasher': '/dishwasher',
              'microwave': '/microwave',
              'freezer': '/freezer',
              'oven': '/oven',
              'dryer': '/dryer',
              'air fryer': '/airfryer',
              'airfryer': '/airfryer',
              'refrigerator': '/refrigerator',
              'fridge': '/refrigerator',
              'shelf life': '/how-long',
              'how long': '/how-long',
              'washing machine': '/washing-machine',
              'refreeze': '/refreeze',
              'what happens': '/what-happens'
            };
            if (applianceMap[rawValue]) {
              window.location.href = applianceMap[rawValue];
              return;
            }
          }

          if (match) {
            window.location.href = match.url;
          } else {
            alert(`We couldn't find a direct guide for "${searchInput.value}". Please select from the suggestions list or browse by category below!`);
          }
        });
      }
    });
  </script>
</Layout>
